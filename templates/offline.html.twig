{% extends 'base.html.twig' %}

{% block title %}Offline | Betechnik IS{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-100 flex items-center justify-center p-4">
    <div class="max-w-md w-full text-center">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
            {# Offline ikona #}
            <div class="w-20 h-20 mx-auto mb-6 bg-slate-100 rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 010 12.728m0 0l-2.829-2.829m2.829 2.829L21 21M15.536 8.464a5 5 0 010 7.072m0 0l-2.829-2.829m-4.243 2.829a4.978 4.978 0 01-1.414-2.83m-1.414 5.658a9 9 0 01-2.167-9.238m7.824 2.167a1 1 0 111.414 1.414m-1.414-1.414L3 3m8.293 8.293l1.414 1.414"/>
                </svg>
            </div>
            
            <h1 class="text-2xl font-bold text-slate-900 mb-2">Jste offline</h1>
            <p class="text-slate-500 mb-6">
                Nemáte připojení k internetu. Zkontrolujte své připojení a zkuste to znovu.
            </p>
            
            <button onclick="window.location.reload()" 
                    class="inline-flex items-center gap-2 px-6 py-3 bg-[rgb(241,97,1)] hover:bg-[rgb(220,88,0)] text-white font-medium rounded-xl transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Zkusit znovu
            </button>
        </div>
        
        <p class="mt-6 text-sm text-slate-400">
            Betechnik IS
        </p>
    </div>
</div>
{% endblock %}
