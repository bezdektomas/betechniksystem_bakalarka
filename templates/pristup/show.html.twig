{% extends 'layout/dashboard.html.twig' %}

{% block title %}{{ pristup.popis }} | Přístupy{% endblock %}

{% block content %}
{# Breadcrumb #}
<nav class="flex items-center space-x-2 text-sm mb-6">
    {% if pristup.zakazka %}
    <a href="{{ path('app_zakazka_list') }}" class="text-slate-500 hover:text-[rgb(241,97,1)] transition-colors">Zakázky</a>
    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <a href="{{ path('app_zakazka_detail', {id: pristup.zakazka.id}) }}" class="text-slate-500 hover:text-[rgb(241,97,1)] transition-colors">{{ pristup.zakazka.name }}</a>
    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    {% else %}
    <a href="{{ path('app_pristup_index') }}" class="text-slate-500 hover:text-[rgb(241,97,1)] transition-colors">Přístupy</a>
    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    {% endif %}
    <span class="text-slate-800 font-medium">Přístup</span>
</nav>

{# Flash messages #}
{% for message in app.flashes('success') %}
    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-green-700">{{ message }}</span>
        </div>
    </div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            <span class="text-red-700">{{ message }}</span>
        </div>
    </div>
{% endfor %}

{# Header #}
<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
    <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 rounded-xl bg-[rgb(241,97,1)]/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-[rgb(241,97,1)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-slate-800">{{ pristup.popis }}</h1>
        </div>
        <p class="text-slate-500">
            {% if pristup.zakazka %}Zakázka: <a href="{{ path('app_zakazka_detail', {id: pristup.zakazka.id}) }}" class="text-[rgb(241,97,1)] hover:underline">{{ pristup.zakazka.name }}</a> • {% endif %}Vytvořeno {{ pristup.createdAt|date('d.m.Y H:i') }}
            {% if pristup.updatedAt %}
                • Upraveno {{ pristup.updatedAt|date('d.m.Y H:i') }}
            {% endif %}
        </p>
    </div>
    
    <div class="flex items-center space-x-3">
        <a href="{{ path('app_pristup_edit', {id: pristup.id}) }}" class="inline-flex items-center px-4 py-2.5 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Upravit
        </a>
        
        <form action="{{ path('app_pristup_delete', {id: pristup.id}) }}" method="post" onsubmit="return confirm('Opravdu chcete smazat tento přístup?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ pristup.id) }}">
            <button type="submit" class="inline-flex items-center px-4 py-2.5 bg-white border border-red-300 text-red-600 font-medium rounded-xl hover:bg-red-50 transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Smazat
            </button>
        </form>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    {# Přihlašovací údaje #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
            <h2 class="text-lg font-semibold text-slate-800">Přihlašovací údaje</h2>
        </div>
        <div class="p-6 space-y-4">
            {# URL #}
            {% if pristup.url %}
            <div>
                <dt class="text-sm font-medium text-slate-500 mb-2">URL pro přihlášení</dt>
                <dd class="flex items-center gap-2">
                    <a href="{{ pristup.url }}" target="_blank" 
                       class="flex-1 px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-[rgb(241,97,1)] hover:bg-slate-100 transition-colors break-all flex items-center gap-2">
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                        {{ pristup.url }}
                    </a>
                    <button type="button" 
                            onclick="copyToClipboard('{{ pristup.url|e('js') }}', this)"
                            class="p-3 text-slate-400 hover:text-[rgb(241,97,1)] hover:bg-slate-100 rounded-xl transition-colors"
                            title="Kopírovat URL">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                    </button>
                </dd>
            </div>
            {% endif %}
            
            {# Uživatelské jméno #}
            <div>
                <dt class="text-sm font-medium text-slate-500 mb-2">Uživatelské jméno</dt>
                <dd class="flex items-center gap-2">
                    {% if pristup.username %}
                        <code class="flex-1 px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-800 font-mono text-lg">{{ pristup.username }}</code>
                        <button type="button" 
                                onclick="copyToClipboard('{{ pristup.username|e('js') }}', this)"
                                class="p-3 text-slate-400 hover:text-[rgb(241,97,1)] hover:bg-slate-100 rounded-xl transition-colors"
                                title="Kopírovat uživatelské jméno">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                            </svg>
                        </button>
                    {% else %}
                        <span class="text-slate-400 italic">Neuvedeno</span>
                    {% endif %}
                </dd>
            </div>
            
            {# Heslo #}
            <div>
                <dt class="text-sm font-medium text-slate-500 mb-2">Heslo</dt>
                <dd class="flex items-center gap-2">
                    {% if pristup.password %}
                        <code class="flex-1 px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-800 font-mono text-lg password-field" data-password="{{ pristup.password|e('html_attr') }}">••••••••</code>
                        <button type="button" 
                                onclick="togglePassword(this)"
                                class="p-3 text-slate-400 hover:text-[rgb(241,97,1)] hover:bg-slate-100 rounded-xl transition-colors"
                                title="Zobrazit/skrýt heslo">
                            <svg class="w-5 h-5 eye-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            <svg class="w-5 h-5 eye-off-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                            </svg>
                        </button>
                        <button type="button" 
                                onclick="copyToClipboard('{{ pristup.password|e('js') }}', this)"
                                class="p-3 text-slate-400 hover:text-[rgb(241,97,1)] hover:bg-slate-100 rounded-xl transition-colors"
                                title="Kopírovat heslo">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                            </svg>
                        </button>
                    {% else %}
                        <span class="text-slate-400 italic">Neuvedeno</span>
                    {% endif %}
                </dd>
            </div>
        </div>
    </div>
    
    {# Informace #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
            <h2 class="text-lg font-semibold text-slate-800">Informace</h2>
        </div>
        <div class="p-6 space-y-4">
            <div>
                <dt class="text-sm font-medium text-slate-500 mb-1">Zakázka</dt>
                <dd>
                    {% if pristup.zakazka %}
                        <a href="{{ path('app_zakazka_detail', {id: pristup.zakazka.id}) }}"
                           class="text-[rgb(241,97,1)] hover:underline font-medium">
                            {{ pristup.zakazka.name }}
                        </a>
                    {% else %}
                        <span class="text-slate-400">—</span>
                    {% endif %}
                </dd>
            </div>
            
            <div>
                <dt class="text-sm font-medium text-slate-500 mb-1">Vytvořil</dt>
                <dd class="text-slate-800">
                    {% if pristup.createdBy %}
                        {{ pristup.createdBy.displayName ?? pristup.createdBy.email }}
                    {% else %}
                        <span class="text-slate-400">—</span>
                    {% endif %}
                </dd>
            </div>
            
            <div>
                <dt class="text-sm font-medium text-slate-500 mb-1">Vytvořeno</dt>
                <dd class="text-slate-800">{{ pristup.createdAt|date('d.m.Y H:i') }}</dd>
            </div>
            
            {% if pristup.updatedAt %}
            <div>
                <dt class="text-sm font-medium text-slate-500 mb-1">Poslední úprava</dt>
                <dd class="text-slate-800">{{ pristup.updatedAt|date('d.m.Y H:i') }}</dd>
            </div>
            {% endif %}
        </div>
    </div>
</div>

{# Zpět na zakázku #}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function copyToClipboard(text, button) {
    navigator.clipboard.writeText(text).then(function() {
        const originalContent = button.innerHTML;
        button.innerHTML = '<svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(function() {
            button.innerHTML = originalContent;
        }, 1500);
    });
}

function togglePassword(button) {
    const container = button.closest('dd');
    const codeEl = container.querySelector('.password-field');
    const eyeIcon = button.querySelector('.eye-icon');
    const eyeOffIcon = button.querySelector('.eye-off-icon');
    
    if (codeEl.textContent === '••••••••') {
        codeEl.textContent = codeEl.dataset.password;
        eyeIcon.classList.add('hidden');
        eyeOffIcon.classList.remove('hidden');
    } else {
        codeEl.textContent = '••••••••';
        eyeIcon.classList.remove('hidden');
        eyeOffIcon.classList.add('hidden');
    }
}
</script>
{% endblock %}
