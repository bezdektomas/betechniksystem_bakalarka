{% extends 'layout/dashboard.html.twig' %}

{% block title %}Docházka{% endblock %}

{% block content %}

{# Header #}
<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
    <div class="flex-1">
        <h1 class="text-2xl font-bold text-slate-800">Docházka</h1>
        <p class="text-slate-500 mt-1">Přehled odpracovaného času</p>
    </div>
    <div class="flex items-center gap-3">
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_dochazka_admin') }}" 
           class="px-4 py-2.5 bg-white border border-slate-300 text-slate-700 rounded-xl hover:bg-slate-50 transition-colors font-medium flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Admin přehled
        </a>
        {% endif %}
        <a href="{{ path('app_dochazka_new') }}" 
           class="px-4 py-2.5 bg-[rgb(241,97,1)] text-white rounded-xl hover:bg-[rgb(220,85,0)] transition-colors font-medium flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
            Nový záznam
        </a>
    </div>
</div>

{# Flash messages #}
{% for message in app.flashes('success') %}
<div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl">
    <div class="flex items-center">
        <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span class="text-green-700">{{ message }}</span>
    </div>
</div>
{% endfor %}
{% for message in app.flashes('error') %}
<div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
    <div class="flex items-center">
        <svg class="w-5 h-5 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        <span class="text-red-700">{{ message }}</span>
    </div>
</div>
{% endfor %}

{# Timer Widget #}
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 mb-6" id="timerCard">
    <div class="px-6 py-4 bg-slate-50 border-b border-slate-200 rounded-t-2xl">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-[rgb(241,97,1)]/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-[rgb(241,97,1)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div>
                <h2 class="text-lg font-semibold text-slate-800">Stopky</h2>
                <p class="text-sm text-slate-500">Měření pracovního času</p>
            </div>
        </div>
    </div>
    <div class="p-6">
        <div class="flex flex-col lg:flex-row items-center gap-6">
            {# Time display #}
            <div class="flex-1 text-center lg:text-left">
                <div class="text-5xl font-mono font-bold text-slate-800" id="timerDisplay">
                    {% if activeTimer %}{{ activeTimer.formattedTime }}{% else %}0m{% endif %}
                </div>
                <div class="mt-2 text-sm text-slate-500" id="timerStatus">
                    {% if activeTimer %}
                        {% if activeTimer.isRunning %}
                            <span class="inline-flex items-center gap-1.5 text-emerald-600">
                                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                                Stopky běží{% if activeTimer.zakazka %} – {{ activeTimer.zakazka.name }}{% endif %}
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1.5 text-amber-600">
                                <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                                Pozastaveno{% if activeTimer.zakazka %} – {{ activeTimer.zakazka.name }}{% endif %}
                            </span>
                        {% endif %}
                    {% else %}
                        Připraveno ke spuštění
                    {% endif %}
                </div>
            </div>

            {# Zakázka select s vyhledáváním #}
            <div class="w-full lg:w-72" id="timerZakazkaContainer">
                <div class="flex gap-2">
                    <div class="flex-1 relative">
                        <input type="text" id="timerZakazkaDisplay" readonly 
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-slate-700 text-sm bg-white cursor-pointer focus:ring-2 focus:ring-[rgb(241,97,1)] focus:border-[rgb(241,97,1)]" 
                               value="{% if activeTimer and activeTimer.zakazka %}{{ activeTimer.zakazka.name }}{% else %}Výběr zakázky (volitelné){% endif %}"
                               {% if activeTimer %}disabled{% endif %}
                               onclick="openZakazkaModal()">
                        <input type="hidden" id="timerZakazka" value="{% if activeTimer and activeTimer.zakazka %}{{ activeTimer.zakazka.id }}{% endif %}">
                    </div>
                    {% if not activeTimer %}
                    <button type="button" onclick="openZakazkaModal()" class="px-3 py-2.5 border border-slate-300 rounded-xl text-slate-600 hover:bg-slate-50 hover:border-slate-400 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </button>
                    {% endif %}
                </div>
            </div>

            {# Controls #}
            <div class="flex items-center gap-3">
                {% if activeTimer %}
                    {% if activeTimer.isRunning %}
                        <button type="button" onclick="timerPause()" class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-amber-500 text-white hover:bg-amber-600 transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>
                        </button>
                    {% else %}
                        <button type="button" onclick="timerResume()" class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-emerald-500 text-white hover:bg-emerald-600 transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        </button>
                    {% endif %}
                    <button type="button" onclick="timerStop()" class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-red-500 text-white hover:bg-red-600 transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h12v12H6z"/></svg>
                    </button>
                {% else %}
                    <button type="button" onclick="timerStart()" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-xl bg-[rgb(241,97,1)] text-white hover:bg-[rgb(230,90,0)] transition-colors shadow-sm">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        Spustit stopky
                    </button>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# Statistiky #}
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
            </div>
            <div>
                <p class="text-sm text-slate-500">Dnes</p>
                <p class="text-2xl font-bold text-slate-800">
                    {% set h = (todayMinutes / 60)|round(0, 'floor') %}
                    {% set m = todayMinutes % 60 %}
                    {% if h > 0 and m > 0 %}{{ h }}h {{ m }}m{% elseif h > 0 %}{{ h }}h{% else %}{{ m }}m{% endif %}
                </p>
            </div>
        </div>
        <p class="text-sm text-slate-500">{{ todayRecords|length }} záznam{{ todayRecords|length == 1 ? '' : (todayRecords|length >= 2 and todayRecords|length <= 4 ? 'y' : 'ů') }}</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
            </div>
            <div>
                <p class="text-sm text-slate-500">Tento týden</p>
                <p class="text-2xl font-bold text-slate-800">
                    {% set h = (weekMinutes / 60)|round(0, 'floor') %}
                    {% set m = weekMinutes % 60 %}
                    {% if h > 0 and m > 0 %}{{ h }}h {{ m }}m{% elseif h > 0 %}{{ h }}h{% else %}{{ m }}m{% endif %}
                </p>
            </div>
        </div>
        <p class="text-sm text-slate-500">{{ weekRecords|length }} záznam{{ weekRecords|length == 1 ? '' : (weekRecords|length >= 2 and weekRecords|length <= 4 ? 'y' : 'ů') }}</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-violet-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                </svg>
            </div>
            <div>
                <p class="text-sm text-slate-500">Počet zakázek</p>
                <p class="text-2xl font-bold text-slate-800">{{ zakazkySummary|length }}</p>
            </div>
        </div>
        <p class="text-sm text-slate-500">
            {% set totalZakMinutes = 0 %}
            {% for item in zakazkySummary %}{% set totalZakMinutes = totalZakMinutes + item.totalMinutes %}{% endfor %}
            Celkem {{ (totalZakMinutes / 60)|round(0, 'floor') }}h odpracováno
        </p>
    </div>
</div>

{# Přehled po zakázkách #}
{% if zakazkySummary|length > 0 %}
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-6">
    <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
        <h2 class="text-lg font-semibold text-slate-800">Odpracováno na zakázkách</h2>
    </div>
    <div class="p-6">
        <div class="space-y-3">
            {% for item in zakazkySummary|slice(0, 5) %}
            <div class="flex items-center justify-between p-3 rounded-xl bg-slate-50">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-[rgb(241,97,1)]/10 flex items-center justify-center">
                        <svg class="w-4 h-4 text-[rgb(241,97,1)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                    </div>
                    {% if item.zakazka %}
                        <a href="{{ path('app_zakazka_detail', {id: item.zakazka.id}) }}" class="text-sm font-medium text-slate-700 hover:text-[rgb(241,97,1)] transition-colors">
                            {{ item.zakazka.name }}
                        </a>
                    {% else %}
                        <span class="text-sm font-medium text-slate-500 italic">Bez zakázky</span>
                    {% endif %}
                </div>
                <div class="text-sm font-semibold text-slate-700">
                    {% set h = (item.totalMinutes / 60)|round(0, 'floor') %}
                    {% set m = item.totalMinutes % 60 %}
                    {% if h > 0 and m > 0 %}{{ h }}h {{ m }}m{% elseif h > 0 %}{{ h }}h{% else %}{{ m }}m{% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

{# Mobilní zobrazení - karty #}
<div class="lg:hidden space-y-3">
    {% if pagination|length > 0 %}
        {% for dochazka in pagination %}
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 hover:shadow-md hover:border-slate-300 transition-all">
            <div class="flex items-start justify-between gap-3 mb-2">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                        <span class="font-semibold text-slate-800">{{ dochazka.datum|date('d.m.Y') }}</span>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-xs font-semibold bg-emerald-100 text-emerald-700">{{ dochazka.formattedTime }}</span>
                    </div>
                    {% if dochazka.zakazka %}
                        <p class="text-sm text-slate-500 mt-0.5 truncate">{{ dochazka.zakazka.name }}</p>
                    {% else %}
                        <p class="text-sm text-slate-400 mt-0.5 italic">Bez zakázky</p>
                    {% endif %}
                </div>
                <div class="flex items-center gap-1 shrink-0">
                    <a href="{{ path('app_dochazka_edit', {id: dochazka.id}) }}" class="p-1.5 text-slate-400 hover:text-[rgb(241,97,1)]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                    </a>
                    <form method="post" action="{{ path('app_dochazka_delete', {id: dochazka.id}) }}" class="inline" onsubmit="return confirm('Opravdu smazat?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dochazka.id) }}">
                        <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                        </button>
                    </form>
                </div>
            </div>
            {% if dochazka.popis %}
                <p class="text-sm text-slate-500">{{ dochazka.popis|slice(0, 80) }}{{ dochazka.popis|length > 80 ? '...' : '' }}</p>
            {% endif %}
        </div>
        {% endfor %}
        {% if pagination.pageCount > 1 %}
        <div>{{ knp_pagination_render(pagination) }}</div>
        {% endif %}
    {% else %}
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 text-center">
        <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="text-lg font-medium text-slate-900 mb-2">Zatím žádné záznamy</h3>
        <p class="text-slate-500">Spusťte stopky nebo přidejte záznam ručně</p>
    </div>
    {% endif %}
</div>

{# Desktop zobrazení - tabulka #}
<div class="hidden lg:block bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    {% if pagination|length > 0 %}
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Datum</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Zakázka</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Čas</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Popis</th>
                    <th class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Akce</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                {% for dochazka in pagination %}
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="text-sm font-medium text-slate-800">{{ dochazka.datum|date('d.m.Y') }}</span>
                    </td>
                    <td class="px-6 py-4">
                        {% if dochazka.zakazka %}
                            <a href="{{ path('app_zakazka_detail', {id: dochazka.zakazka.id}) }}" class="text-sm font-medium text-slate-700 hover:text-[rgb(241,97,1)] transition-colors">
                                {{ dochazka.zakazka.name }}
                            </a>
                        {% else %}
                            <span class="text-sm text-slate-500 italic">Bez zakázky</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-semibold bg-emerald-100 text-emerald-700">
                            {{ dochazka.formattedTime }}
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        {% if dochazka.popis %}
                            <span class="text-sm text-slate-600">{{ dochazka.popis|slice(0, 50) }}{{ dochazka.popis|length > 50 ? '...' : '' }}</span>
                        {% else %}
                            <span class="text-sm text-slate-400">—</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right">
                        <div class="flex items-center justify-end gap-1">
                            <a href="{{ path('app_dochazka_edit', {id: dochazka.id}) }}" class="p-2 text-slate-500 hover:text-[rgb(241,97,1)] hover:bg-[rgb(241,97,1)]/10 rounded-lg transition-colors" title="Upravit">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </a>
                            <form method="post" action="{{ path('app_dochazka_delete', {id: dochazka.id}) }}" class="inline" onsubmit="return confirm('Opravdu smazat?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dochazka.id) }}">
                                <button type="submit" class="p-2 text-slate-500 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Smazat">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    {# Pagination #}
    {% if pagination.pageCount > 1 %}
    <div class="px-6 py-4 border-t border-slate-200">
        {{ knp_pagination_render(pagination) }}
    </div>
    {% endif %}
    {% else %}
    <div class="p-12 text-center">
        <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="text-lg font-medium text-slate-900 mb-2">Zatím žádné záznamy</h3>
        <p class="text-slate-500 mb-6">Spusťte stopky nebo přidejte záznam ručně</p>
    </div>
    {% endif %}
</div>

{# Stop Timer Modal #}
<div id="stopTimerModal" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" onclick="closeStopModal()"></div>
    <div class="fixed inset-0 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6 relative">
            <button onclick="closeStopModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
            <h3 class="text-lg font-semibold text-slate-800 mb-4">Uložit docházku</h3>
            <div class="mb-4">
                <p class="text-sm text-slate-600">Naměřený čas: <span id="modalTime" class="font-semibold text-[rgb(241,97,1)]">0m</span></p>
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Popis práce (volitelné)</label>
                <textarea id="stopPopis" rows="3" class="w-full px-4 py-2.5 border border-slate-300 rounded-xl text-slate-700 text-sm focus:ring-2 focus:ring-[rgb(241,97,1)] focus:border-[rgb(241,97,1)] resize-none" placeholder="Co jste dělali..."></textarea>
            </div>
            <div class="flex items-center justify-end gap-3">
                <button type="button" onclick="timerCancel()" class="px-4 py-2 text-sm font-medium text-red-600 hover:text-red-700">Zrušit bez uložení</button>
                <button type="button" onclick="confirmStopTimer()" class="px-4 py-2.5 text-sm font-semibold rounded-xl bg-[rgb(241,97,1)] text-white hover:bg-[rgb(230,90,0)] transition-colors">Uložit docházku</button>
            </div>
        </div>
    </div>
</div>

{# Zakázka Search Modal #}
<div id="zakazkaModal" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" onclick="closeZakazkaModal()"></div>
    <div class="fixed inset-0 flex items-start justify-center p-4 pt-20">
        <div class="bg-white rounded-2xl shadow-xl max-w-lg w-full relative">
            <div class="p-4 border-b border-slate-200">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <input type="text" id="zakazkaSearch" 
                           class="flex-1 text-sm text-slate-700 placeholder-slate-400 outline-none" 
                           placeholder="Hledat zakázku..."
                           oninput="filterZakazky(this.value)">
                    <button onclick="closeZakazkaModal()" class="text-slate-400 hover:text-slate-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>
            <div id="zakazkaList" class="max-h-80 overflow-y-auto">
                <button type="button" onclick="selectZakazka('', 'Bez zakázky')" class="zakazka-item w-full px-4 py-3 text-left text-sm text-slate-600 hover:bg-slate-50 flex items-center gap-3 border-b border-slate-100" data-name="bez zakázky">
                    <div class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center">
                        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                        </svg>
                    </div>
                    <span>Bez zakázky</span>
                </button>
                {% for zakazka in zakazky %}
                <button type="button" onclick="selectZakazka('{{ zakazka.id }}', '{{ zakazka.name|e('js') }}')" class="zakazka-item w-full px-4 py-3 text-left text-sm text-slate-700 hover:bg-slate-50 flex items-center gap-3 border-b border-slate-100 last:border-0" data-name="{{ zakazka.name|lower }}">
                    <div class="w-8 h-8 rounded-lg bg-[rgb(241,97,1)]/10 flex items-center justify-center">
                        <svg class="w-4 h-4 text-[rgb(241,97,1)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                    </div>
                    <span>{{ zakazka.name }}</span>
                </button>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<script>
// Zakázka modal functions
function openZakazkaModal() {
    document.getElementById('zakazkaModal').classList.remove('hidden');
    document.getElementById('zakazkaSearch').value = '';
    document.getElementById('zakazkaSearch').focus();
    filterZakazky('');
}

function closeZakazkaModal() {
    document.getElementById('zakazkaModal').classList.add('hidden');
}

function filterZakazky(query) {
    const items = document.querySelectorAll('.zakazka-item');
    const q = query.toLowerCase().trim();
    items.forEach(item => {
        const name = item.dataset.name;
        item.style.display = (q === '' || name.includes(q)) ? 'flex' : 'none';
    });
}

function selectZakazka(id, name) {
    document.getElementById('timerZakazka').value = id;
    document.getElementById('timerZakazkaDisplay').value = name;
    closeZakazkaModal();
}

// Close modal on Escape
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !document.getElementById('zakazkaModal').classList.contains('hidden')) {
        closeZakazkaModal();
    }
});
</script>

<script>
let timerInterval = null;
let timerStartTime = null;
let timerAccumulatedMinutes = 0;
let timerIsRunning = false;

{% if activeTimer %}
timerStartTime = new Date('{{ activeTimer.startedAt|date('c') }}');
timerAccumulatedMinutes = {{ activeTimer.accumulatedMinutes }};
timerIsRunning = {{ activeTimer.isRunning ? 'true' : 'false' }};
if (timerIsRunning) startTimerDisplay();
{% endif %}

function formatTime(minutes) {
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    if (h > 0 && m > 0) return `${h}h ${m}m`;
    if (h > 0) return `${h}h`;
    return `${m}m`;
}

function updateTimerDisplay() {
    let totalMinutes = timerAccumulatedMinutes;
    if (timerIsRunning && timerStartTime) {
        const diff = Math.floor((new Date() - timerStartTime) / 1000 / 60);
        totalMinutes += diff;
    }
    document.getElementById('timerDisplay').textContent = formatTime(totalMinutes);
}

function startTimerDisplay() {
    if (timerInterval) clearInterval(timerInterval);
    timerInterval = setInterval(updateTimerDisplay, 1000);
    updateTimerDisplay();
}

async function timerStart() {
    const zakazkaId = document.getElementById('timerZakazka')?.value || '';
    const formData = new FormData();
    if (zakazkaId) formData.append('zakazka_id', zakazkaId);
    
    const response = await fetch('{{ path('app_dochazka_timer_start') }}', { method: 'POST', body: formData });
    const data = await response.json();
    if (data.success) location.reload();
    else alert(data.message);
}

async function timerPause() {
    const response = await fetch('{{ path('app_dochazka_timer_pause') }}', { method: 'POST' });
    const data = await response.json();
    if (data.success) location.reload();
    else alert(data.message);
}

async function timerResume() {
    const response = await fetch('{{ path('app_dochazka_timer_resume') }}', { method: 'POST' });
    const data = await response.json();
    if (data.success) location.reload();
    else alert(data.message);
}

function timerStop() {
    document.getElementById('modalTime').textContent = document.getElementById('timerDisplay').textContent;
    document.getElementById('stopTimerModal').classList.remove('hidden');
}

function closeStopModal() {
    document.getElementById('stopTimerModal').classList.add('hidden');
}

async function confirmStopTimer() {
    const popis = document.getElementById('stopPopis').value;
    const formData = new FormData();
    if (popis) formData.append('popis', popis);
    
    const response = await fetch('{{ path('app_dochazka_timer_stop') }}', { method: 'POST', body: formData });
    const data = await response.json();
    if (data.success) location.reload();
    else alert(data.message);
}

async function timerCancel() {
    if (!confirm('Opravdu zrušit stopky bez uložení?')) return;
    const response = await fetch('{{ path('app_dochazka_timer_cancel') }}', { method: 'POST' });
    const data = await response.json();
    if (data.success) location.reload();
    else alert(data.message);
}

if (timerIsRunning) startTimerDisplay();
else if (timerAccumulatedMinutes > 0) updateTimerDisplay();
</script>
{% endblock %}
