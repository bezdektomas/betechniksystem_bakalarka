{% extends 'layout/dashboard.html.twig' %}

{% block title %}Docházka - Admin{% endblock %}

{% block content %}

{# Header #}
<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
    <div class="flex-1">
        <h1 class="text-2xl font-bold text-slate-800">Docházka - Admin přehled</h1>
        <p class="text-slate-500 mt-1">Přehled docházky všech zaměstnanců</p>
    </div>
    <div class="flex items-center gap-3">
        <a href="{{ path('app_dochazka_index') }}" 
           class="px-4 py-2.5 bg-white border border-slate-300 text-slate-700 rounded-xl hover:bg-slate-50 transition-colors font-medium flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Moje docházka
        </a>
    </div>
</div>

{# Flash messages #}
{% for message in app.flashes('success') %}
<div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl">
    <div class="flex items-center">
        <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span class="text-green-700">{{ message }}</span>
    </div>
</div>
{% endfor %}
{% for message in app.flashes('error') %}
<div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
    <div class="flex items-center">
        <svg class="w-5 h-5 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        <span class="text-red-700">{{ message }}</span>
    </div>
</div>
{% endfor %}

{# Souhrn po zaměstnancích #}
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-6">
    <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-violet-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
            </div>
            <div>
                <h2 class="text-lg font-semibold text-slate-800">Přehled zaměstnanců</h2>
                <p class="text-sm text-slate-500">Celkový odpracovaný čas</p>
            </div>
        </div>
    </div>
    <div class="p-6">
        {% if usersSummary|length > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for item in usersSummary %}
            <a href="{{ path('app_dochazka_admin', {user: item.user.id}) }}" 
               class="flex items-center gap-4 p-4 rounded-xl border {% if filterUserId == item.user.id %}border-[rgb(241,97,1)] bg-[rgb(241,97,1)]/5{% else %}border-slate-200 hover:border-slate-300{% endif %} transition-colors">
                {% if item.user.profilePicture %}
                <img src="{{ asset('uploads/profiles/' ~ item.user.profilePicture) }}" 
                     alt="{{ item.user.displayName }}"
                     class="w-12 h-12 rounded-full object-cover">
                {% else %}
                <div class="w-12 h-12 rounded-full bg-slate-200 flex items-center justify-center text-lg font-semibold text-slate-600">
                    {{ item.user.displayName|slice(0,1)|upper }}
                </div>
                {% endif %}
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-slate-800 truncate">{{ item.user.displayName }}</p>
                    <p class="text-xs text-slate-500">{{ item.user.email }}</p>
                </div>
                <div class="text-right">
                    <p class="text-lg font-bold text-[rgb(241,97,1)]">
                        {% set h = (item.totalMinutes / 60)|round(0, 'floor') %}
                        {% set m = item.totalMinutes % 60 %}
                        {% if h > 0 and m > 0 %}{{ h }}h {{ m }}m{% elseif h > 0 %}{{ h }}h{% else %}{{ m }}m{% endif %}
                    </p>
                </div>
            </a>
            {% endfor %}
        </div>
        {% else %}
        <p class="text-center text-slate-500 py-8">Zatím žádná docházka</p>
        {% endif %}
    </div>
</div>

{# Filtr reset #}
{% if filterUserId or filterZakazkaId %}
<div class="flex items-center gap-3 mb-6">
    <span class="text-sm text-slate-500">Aktivní filtr:</span>
    {% if filterUserId %}
    <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-slate-100 text-sm text-slate-700">
        Zaměstnanec
        <a href="{{ path('app_dochazka_admin', {zakazka: filterZakazkaId}) }}" class="ml-1 text-slate-400 hover:text-slate-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </a>
    </span>
    {% endif %}
    <a href="{{ path('app_dochazka_admin') }}" class="text-sm text-[rgb(241,97,1)] hover:underline">Zrušit filtr</a>
</div>
{% endif %}

{# Nadpis sekce #}
<h2 class="text-lg font-semibold text-slate-800 mb-3">Všechny záznamy docházky</h2>

{# Mobilní zobrazení - karty #}
<div class="lg:hidden space-y-3">
    {% if pagination|length > 0 %}
        {% for dochazka in pagination %}
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 hover:shadow-md hover:border-slate-300 transition-all">
            <div class="flex items-start justify-between gap-3 mb-2">
                <div class="flex items-center gap-2 flex-1 min-w-0">
                    {% if dochazka.user.profilePicture %}
                    <img src="{{ asset('uploads/profiles/' ~ dochazka.user.profilePicture) }}" alt="{{ dochazka.user.displayName }}" class="w-8 h-8 rounded-full object-cover shrink-0">
                    {% else %}
                    <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-xs font-semibold text-slate-600 shrink-0">
                        {{ dochazka.user.displayName|slice(0,1)|upper }}
                    </div>
                    {% endif %}
                    <div class="min-w-0">
                        <p class="font-semibold text-slate-800 truncate">{{ dochazka.user.displayName }}</p>
                        <div class="flex items-center gap-2 mt-0.5">
                            <span class="text-xs text-slate-500">{{ dochazka.datum|date('d.m.Y') }}</span>
                            <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-xs font-semibold bg-emerald-100 text-emerald-700">{{ dochazka.formattedTime }}</span>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-1 shrink-0">
                    <a href="{{ path('app_dochazka_edit', {id: dochazka.id}) }}" class="p-1.5 text-slate-400 hover:text-[rgb(241,97,1)]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                    </a>
                    <form method="post" action="{{ path('app_dochazka_delete', {id: dochazka.id}) }}" class="inline" onsubmit="return confirm('Opravdu smazat?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dochazka.id) }}">
                        <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                        </button>
                    </form>
                </div>
            </div>
            {% if dochazka.zakazka %}
                <p class="text-sm text-slate-600 ml-10">
                    <svg class="w-3.5 h-3.5 inline mr-1 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    {{ dochazka.zakazka.name }}
                </p>
            {% endif %}
            {% if dochazka.popis %}
                <p class="text-sm text-slate-500 ml-10 mt-1">{{ dochazka.popis|slice(0, 80) }}{{ dochazka.popis|length > 80 ? '...' : '' }}</p>
            {% endif %}
        </div>
        {% endfor %}
        {% if pagination.pageCount > 1 %}
        <div>{{ knp_pagination_render(pagination) }}</div>
        {% endif %}
    {% else %}
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 text-center">
        <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="text-lg font-medium text-slate-900 mb-2">Žádné záznamy</h3>
        <p class="text-slate-500">Nenalezeny žádné záznamy docházky</p>
    </div>
    {% endif %}
</div>

{# Desktop zobrazení - tabulka #}
<div class="hidden lg:block bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    {% if pagination|length > 0 %}
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Zaměstnanec</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Datum</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Zakázka</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Čas</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Popis</th>
                    <th class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Akce</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                {% for dochazka in pagination %}
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center gap-3">
                            {% if dochazka.user.profilePicture %}
                            <img src="{{ asset('uploads/profiles/' ~ dochazka.user.profilePicture) }}" 
                                 alt="{{ dochazka.user.displayName }}"
                                 class="w-8 h-8 rounded-full object-cover">
                            {% else %}
                            <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-xs font-semibold text-slate-600">
                                {{ dochazka.user.displayName|slice(0,1)|upper }}
                            </div>
                            {% endif %}
                            <div>
                                <p class="text-sm font-medium text-slate-800">{{ dochazka.user.displayName }}</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="text-sm font-medium text-slate-800">{{ dochazka.datum|date('d.m.Y') }}</span>
                    </td>
                    <td class="px-6 py-4">
                        {% if dochazka.zakazka %}
                            <a href="{{ path('app_zakazka_detail', {id: dochazka.zakazka.id}) }}" class="text-sm font-medium text-slate-700 hover:text-[rgb(241,97,1)] transition-colors">
                                {{ dochazka.zakazka.name }}
                            </a>
                        {% else %}
                            <span class="text-sm text-slate-500 italic">Bez zakázky</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-semibold bg-emerald-100 text-emerald-700">
                            {{ dochazka.formattedTime }}
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        {% if dochazka.popis %}
                            <span class="text-sm text-slate-600">{{ dochazka.popis|slice(0, 50) }}{{ dochazka.popis|length > 50 ? '...' : '' }}</span>
                        {% else %}
                            <span class="text-sm text-slate-400">—</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right">
                        <div class="flex items-center justify-end gap-1">
                            <a href="{{ path('app_dochazka_edit', {id: dochazka.id}) }}" class="p-2 text-slate-500 hover:text-[rgb(241,97,1)] hover:bg-[rgb(241,97,1)]/10 rounded-lg transition-colors" title="Upravit">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </a>
                            <form method="post" action="{{ path('app_dochazka_delete', {id: dochazka.id}) }}" class="inline" onsubmit="return confirm('Opravdu smazat?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dochazka.id) }}">
                                <button type="submit" class="p-2 text-slate-500 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Smazat">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if pagination.pageCount > 1 %}
    <div class="px-6 py-4 border-t border-slate-200">
        {{ knp_pagination_render(pagination) }}
    </div>
    {% endif %}
    {% else %}
    <div class="p-12 text-center">
        <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="text-lg font-medium text-slate-900 mb-2">Žádné záznamy</h3>
        <p class="text-slate-500">Nenalezeny žádné záznamy docházky</p>
    </div>
    {% endif %}
</div>
{% endblock %}
