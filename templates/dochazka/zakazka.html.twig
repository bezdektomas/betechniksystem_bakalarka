{% extends 'layout/dashboard.html.twig' %}

{% block title %}Docházka - {{ zakazka.name }}{% endblock %}

{% block content %}

{# Header #}
<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
    <div class="flex-1">
        <h1 class="text-2xl font-bold text-slate-800">Docházka na zakázce</h1>
        <p class="text-slate-500 mt-1">{{ zakazka.name }}</p>
    </div>
    <div class="flex items-center gap-3">
        <a href="{{ path('app_zakazka_detail', {id: zakazka.id}) }}" 
           class="px-4 py-2.5 bg-white border border-slate-300 text-slate-700 rounded-xl hover:bg-slate-50 transition-colors font-medium flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Zpět na zakázku
        </a>
        <a href="{{ path('app_dochazka_new', {zakazka: zakazka.id}) }}" 
           class="px-4 py-2.5 bg-[rgb(241,97,1)] text-white rounded-xl hover:bg-[rgb(220,85,0)] transition-colors font-medium flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
            Přidat záznam
        </a>
    </div>
</div>

{# Statistika #}
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-6">
    <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-[rgb(241,97,1)]/10 flex items-center justify-center">
                    <svg class="w-5 h-5 text-[rgb(241,97,1)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-lg font-semibold text-slate-800">Souhrn</h2>
                    <p class="text-sm text-slate-500">Celková odpracovaná doba</p>
                </div>
            </div>
            <div class="text-right">
                <p class="text-3xl font-bold text-[rgb(241,97,1)]">
                    {% set h = (totalMinutes / 60)|round(0, 'floor') %}
                    {% set m = totalMinutes % 60 %}
                    {% if h > 0 and m > 0 %}{{ h }}h {{ m }}m{% elseif h > 0 %}{{ h }}h{% else %}{{ m }}m{% endif %}
                </p>
                <p class="text-sm text-slate-500">{{ pagination|length }} záznam{{ pagination|length == 1 ? '' : (pagination|length >= 2 and pagination|length <= 4 ? 'y' : 'ů') }}</p>
            </div>
        </div>
    </div>
</div>

{# Seznam docházky #}
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    {% if pagination|length > 0 %}
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Datum</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Zaměstnanec</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Čas</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Popis</th>
                    <th class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Akce</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                {% for dochazka in pagination %}
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="text-sm font-medium text-slate-800">{{ dochazka.datum|date('d.m.Y') }}</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center gap-2">
                            {% if dochazka.user.profilePicture %}
                            <img src="{{ asset('uploads/profiles/' ~ dochazka.user.profilePicture) }}" 
                                 alt="{{ dochazka.user.displayName }}"
                                 class="w-7 h-7 rounded-full object-cover">
                            {% else %}
                            <div class="w-7 h-7 rounded-full bg-slate-200 flex items-center justify-center text-xs font-semibold text-slate-600">
                                {{ dochazka.user.displayName|slice(0,1)|upper }}
                            </div>
                            {% endif %}
                            <span class="text-sm text-slate-700">{{ dochazka.user.displayName }}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-semibold bg-emerald-100 text-emerald-700">
                            {{ dochazka.formattedTime }}
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        {% if dochazka.popis %}
                            <span class="text-sm text-slate-600">{{ dochazka.popis|slice(0, 50) }}{{ dochazka.popis|length > 50 ? '...' : '' }}</span>
                        {% else %}
                            <span class="text-sm text-slate-400">—</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right">
                        {% if dochazka.user == app.user or is_granted('ROLE_ADMIN') %}
                        <div class="flex items-center justify-end gap-1">
                            <a href="{{ path('app_dochazka_edit', {id: dochazka.id}) }}" class="p-2 text-slate-500 hover:text-[rgb(241,97,1)] hover:bg-[rgb(241,97,1)]/10 rounded-lg transition-colors" title="Upravit">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </a>
                            <form method="post" action="{{ path('app_dochazka_delete', {id: dochazka.id}) }}" class="inline" onsubmit="return confirm('Opravdu smazat?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dochazka.id) }}">
                                <button type="submit" class="p-2 text-slate-500 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Smazat">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if pagination.pageCount > 1 %}
    <div class="px-6 py-4 border-t border-slate-200">
        {{ knp_pagination_render(pagination) }}
    </div>
    {% endif %}
    {% else %}
    <div class="p-12 text-center">
        <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="text-lg font-medium text-slate-900 mb-2">Zatím žádná docházka</h3>
        <p class="text-slate-500 mb-6">Na této zakázce není žádný záznam docházky</p>
        <a href="{{ path('app_dochazka_new', {zakazka: zakazka.id}) }}" 
           class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold rounded-xl bg-[rgb(241,97,1)] text-white hover:bg-[rgb(230,90,0)] transition-colors shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Přidat první záznam
        </a>
    </div>
    {% endif %}
</div>
{% endblock %}
