{# Mobile overlay #}
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 lg:hidden hidden"></div>

{# Sidebar #}
<aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-64 bg-slate-900 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
    {# Logo #}
    <div class="flex items-center justify-between h-16 px-6 border-b border-slate-800">
        <a href="{{ path('app_dashboard') }}" class="flex items-center space-x-3">
            <img src="{{ asset('img/logo.png') }}" alt="Betechnik" class="h-8">
        </a>
        <button id="sidebar-close" class="lg:hidden text-slate-400 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>
    
    {# Navigation #}
    <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto scrollbar-thin">
        {# Dashboard #}
        <a href="{{ path('app_dashboard') }}" class="flex items-center px-4 py-3 rounded-xl {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'bg-[rgb(241,97,1)] text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }} transition-colors">
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span class="font-medium">Nástěnka</span>
        </a>
        
        {# Zakázky #}
        {% set is_zakazka_route = app.request.attributes.get('_route') starts with 'app_zakazka' %}
        <a href="{{ path('app_zakazka_list') }}" class="flex items-center px-4 py-3 rounded-xl {{ is_zakazka_route ? 'bg-[rgb(241,97,1)] text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }} transition-colors">
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            <span class="font-medium">Zakázky</span>
        </a>
        
        {# Fakturace #}
        {% set is_faktura_route = app.request.attributes.get('_route') starts with 'app_faktura' %}
        <a href="{{ path('app_faktura_index') }}" class="flex items-center px-4 py-3 rounded-xl {{ is_faktura_route ? 'bg-[rgb(241,97,1)] text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }} transition-colors">
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <span class="font-medium">Fakturace</span>
        </a>
        
        {# Docházka #}
        {% set is_dochazka_route = app.request.attributes.get('_route') starts with 'app_dochazka' %}
        <a href="{{ path('app_dochazka_index') }}" class="flex items-center px-4 py-3 rounded-xl {{ is_dochazka_route ? 'bg-[rgb(241,97,1)] text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }} transition-colors">
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="font-medium">Docházka</span>
        </a>
        
        {# Přístupy #}
        {% set is_pristup_route = app.request.attributes.get('_route') starts with 'app_pristup' %}
        <a href="{{ path('app_pristup_index') }}" class="flex items-center px-4 py-3 rounded-xl {{ is_pristup_route ? 'bg-[rgb(241,97,1)] text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }} transition-colors">
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
            </svg>
            <span class="font-medium">Přístupy</span>
        </a>
        
        {# Divider #}
        <div class="border-t border-slate-800 my-4"></div>
        
        {# Chat #}
        {% set is_chat_route = app.request.attributes.get('_route') starts with 'app_chat' %}
        <a href="{{ path('app_chat_index') }}" class="flex items-center px-4 py-3 rounded-xl {{ is_chat_route ? 'bg-[rgb(241,97,1)] text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }} transition-colors">
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            <span class="font-medium">Chat</span>
        </a>
        
        {# Nastavení - pro všechny přihlášené uživatele #}
        {% set is_nastaveni_route = app.request.attributes.get('_route') starts with 'app_nastaveni' %}
        <a href="{{ path('app_nastaveni_index') }}" class="flex items-center px-4 py-3 rounded-xl {{ is_nastaveni_route ? 'bg-[rgb(241,97,1)] text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }} transition-colors">
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="font-medium">Nastavení</span>
        </a>
    </nav>
    
    {# User Info - kliknutelné pro přechod na profil #}
    <a href="{{ path('app_nastaveni_index') }}" class="block border-t border-slate-800 p-4 hover:bg-slate-800 transition-colors">
        <div class="flex items-center space-x-3">
            {% if app.user.profilePicture %}
            <img src="{{ asset('uploads/profiles/' ~ app.user.profilePicture) }}" 
                 alt="{{ app.user.displayName }}"
                 class="w-10 h-10 rounded-full object-cover">
            {% else %}
            <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center text-white font-medium">
                {{ app.user.displayName|first|upper }}
            </div>
            {% endif %}
            <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-white truncate">{{ app.user.displayName }}</p>
                <p class="text-xs text-slate-400 truncate">{{ app.user.email }}</p>
            </div>
            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
        </div>
    </a>
</aside>
