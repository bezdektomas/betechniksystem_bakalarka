{# Tailwind Pagination Template #}
{% if pageCount > 1 %}
<nav class="flex items-center justify-between mt-6" aria-label="Pagination">
    {# Info o stránkování #}
    <div class="text-sm text-slate-600">
        Zobrazeno <span class="font-medium text-slate-900">{{ (current - 1) * pageRange + 1 }}</span>
        až <span class="font-medium text-slate-900">{{ current == pageCount ? totalCount : current * pageRange }}</span>
        z <span class="font-medium text-slate-900">{{ totalCount }}</span> položek
    </div>
    
    {# Stránkovací tlačítka #}
    <div class="flex items-center space-x-1">
        {# První stránka #}
        {% if first is defined and current > 1 %}
            <a href="{{ path(route, query|merge({(pageParameterName): first})) }}" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors" title="První stránka">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
                </svg>
            </a>
        {% endif %}
        
        {# Předchozí stránka #}
        {% if previous is defined %}
            <a href="{{ path(route, query|merge({(pageParameterName): previous})) }}" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors" title="Předchozí">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </a>
        {% else %}
            <span class="p-2 text-slate-300 cursor-not-allowed">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </span>
        {% endif %}
        
        {# Čísla stránek #}
        {% for page in pagesInRange %}
            {% if page == current %}
                <span class="px-4 py-2 bg-[rgb(241,97,1)] text-white font-medium rounded-lg">
                    {{ page }}
                </span>
            {% else %}
                <a href="{{ path(route, query|merge({(pageParameterName): page})) }}" class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-lg transition-colors font-medium">
                    {{ page }}
                </a>
            {% endif %}
        {% endfor %}
        
        {# Další stránka #}
        {% if next is defined %}
            <a href="{{ path(route, query|merge({(pageParameterName): next})) }}" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors" title="Další">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        {% else %}
            <span class="p-2 text-slate-300 cursor-not-allowed">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </span>
        {% endif %}
        
        {# Poslední stránka #}
        {% if last is defined and current < pageCount %}
            <a href="{{ path(route, query|merge({(pageParameterName): last})) }}" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors" title="Poslední stránka">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
                </svg>
            </a>
        {% endif %}
    </div>
</nav>
{% endif %}
