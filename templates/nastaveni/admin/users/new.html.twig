{% extends 'layout/dashboard.html.twig' %}

{% block title %}Nový uživatel – Administrace{% endblock %}

{% block content %}
<div>
    {# Breadcrumb #}
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <a href="{{ path('app_nastaveni_index') }}" class="hover:text-[rgb(241,97,1)] transition-colors">Nastavení</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <a href="{{ path('app_nastaveni_admin_users') }}" class="hover:text-[rgb(241,97,1)] transition-colors">Uživatelé</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800 font-medium">Nový uživatel</span>
    </nav>

    {# Header #}
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-slate-900">Vytvořit nového uživatele</h1>
        <p class="text-slate-500 mt-1">Zadejte údaje pro nový uživatelský účet</p>
    </div>

    {# Flash messages #}
    {% for message in app.flashes('success') %}
    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-green-700">{{ message }}</span>
        </div>
    </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            <span class="text-red-700">{{ message }}</span>
        </div>
    </div>
    {% endfor %}

    {# Formulář #}
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
        {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
            
            {# Email #}
            <div>
                {{ form_label(form.email, 'Email', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1'}}) }}
                <span class="text-red-500">*</span>
                {{ form_widget(form.email) }}
                {{ form_errors(form.email) }}
            </div>

            {# Jméno #}
            <div>
                {{ form_label(form.name, 'Jméno', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1'}}) }}
                {{ form_widget(form.name) }}
                <p class="text-sm text-slate-500 mt-1">{{ form.name.vars.help }}</p>
                {{ form_errors(form.name) }}
            </div>

            {# Heslo #}
            <div>
                {{ form_label(form.plainPassword, 'Heslo', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1'}}) }}
                <span class="text-red-500">*</span>
                <div class="relative">
                    {{ form_widget(form.plainPassword, {'attr': {'class': 'w-full px-4 py-2 pr-12 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[rgb(241,97,1)] focus:border-transparent transition-all', 'id': 'password'}}) }}
                    <button type="button" 
                            onclick="togglePassword()"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                        <svg id="eye-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                        <svg id="eye-closed" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                        </svg>
                    </button>
                </div>
                {{ form_errors(form.plainPassword) }}
            </div>

            {# Role #}
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Role</label>
                <div class="space-y-3">
                    <label class="flex items-center gap-3 p-4 bg-slate-50 border border-slate-200 rounded-xl cursor-pointer hover:bg-slate-100 transition-colors">
                        <input type="checkbox" 
                               checked
                               disabled
                               class="w-5 h-5 text-[rgb(241,97,1)] border-slate-300 rounded focus:ring-[rgb(241,97,1)]">
                        <div>
                            <p class="font-medium text-slate-900">Uživatel</p>
                            <p class="text-sm text-slate-500">Základní přístup k aplikaci</p>
                        </div>
                    </label>
                    {% for child in form.roles %}
                    <label class="flex items-center gap-3 p-4 bg-slate-50 border border-slate-200 rounded-xl cursor-pointer hover:bg-slate-100 transition-colors has-[:checked]:bg-[rgb(241,97,1)]/5 has-[:checked]:border-[rgb(241,97,1)]">
                        {{ form_widget(child, {'attr': {'class': 'w-5 h-5 text-[rgb(241,97,1)] border-slate-300 rounded focus:ring-[rgb(241,97,1)]'}}) }}
                        <div>
                            <p class="font-medium text-slate-900">{{ child.vars.label }}</p>
                            <p class="text-sm text-slate-500">Plná správa systému, uživatelů a nastavení</p>
                        </div>
                    </label>
                    {% endfor %}
                </div>
            </div>

            {# Aktivní #}
            <div>
                <label class="flex items-center gap-3 p-4 bg-slate-50 border border-slate-200 rounded-xl cursor-pointer hover:bg-slate-100 transition-colors">
                    {{ form_widget(form.isActive, {'attr': {'class': 'w-5 h-5 text-[rgb(241,97,1)] border-slate-300 rounded focus:ring-[rgb(241,97,1)]'}}) }}
                    <div>
                        <p class="font-medium text-slate-900">Aktivní účet</p>
                        <p class="text-sm text-slate-500">Uživatel se může přihlásit do systému</p>
                    </div>
                </label>
            </div>

            {# Akce #}
            <div class="flex gap-3 pt-4 border-t border-slate-200">
                <a href="{{ path('app_nastaveni_admin_users') }}" 
                   class="flex-1 px-4 py-2.5 text-center border border-slate-300 text-slate-700 hover:bg-slate-50 font-medium rounded-lg transition-colors">
                    Zrušit
                </a>
                <button type="submit" 
                        class="flex-1 px-4 py-2.5 bg-[rgb(241,97,1)] hover:bg-[rgb(220,85,0)] text-white font-medium rounded-lg transition-colors shadow-sm">
                    Vytvořit uživatele
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>

<script>
function togglePassword() {
    const input = document.getElementById('password');
    const eyeOpen = document.getElementById('eye-open');
    const eyeClosed = document.getElementById('eye-closed');
    
    if (input.type === 'password') {
        input.type = 'text';
        eyeOpen.classList.add('hidden');
        eyeClosed.classList.remove('hidden');
    } else {
        input.type = 'password';
        eyeOpen.classList.remove('hidden');
        eyeClosed.classList.add('hidden');
    }
}
</script>
{% endblock %}

