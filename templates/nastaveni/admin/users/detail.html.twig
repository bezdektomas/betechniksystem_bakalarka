{% extends 'layout/dashboard.html.twig' %}

{% block title %}{{ user.displayName }} – Detail uživatele{% endblock %}

{% block content %}
<div>
    {# Breadcrumb #}
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <a href="{{ path('app_nastaveni_index') }}" class="hover:text-[rgb(241,97,1)] transition-colors">Nastavení</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <a href="{{ path('app_nastaveni_admin_users') }}" class="hover:text-[rgb(241,97,1)] transition-colors">Uživatelé</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800 font-medium">{{ user.displayName }}</span>
    </nav>

    {# Flash messages #}
    {% for message in app.flashes('success') %}
    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-green-700">{{ message }}</span>
        </div>
    </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            <span class="text-red-700">{{ message }}</span>
        </div>
    </div>
    {% endfor %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Levá strana - Info uživatele #}
        <div class="lg:col-span-1 space-y-6">
            {# Profil kartu #}
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="h-20 bg-gradient-to-r from-[rgb(241,97,1)] to-[rgb(200,70,0)]"></div>
                <div class="px-6 pb-6">
                    <div class="-mt-10 mb-4">
                        {% if user.profilePicture %}
                        <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" 
                             alt="{{ user.displayName }}"
                             class="w-20 h-20 rounded-full object-cover border-4 border-white shadow-lg">
                        {% else %}
                        <div class="w-20 h-20 rounded-full bg-white border-4 border-white shadow-lg flex items-center justify-center text-2xl font-bold text-[rgb(241,97,1)] bg-[rgb(241,97,1)]/10">
                            {{ user.displayName|first|upper }}
                        </div>
                        {% endif %}
                    </div>
                    <h2 class="text-xl font-bold text-slate-900">{{ user.displayName }}</h2>
                    <p class="text-slate-500">{{ user.email }}</p>
                    
                    <div class="flex flex-wrap gap-2 mt-4">
                        {% if 'ROLE_ADMIN' in user.roles %}
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-[rgb(241,97,1)]/10 text-[rgb(241,97,1)]">
                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                            </svg>
                            Administrátor
                        </span>
                        {% endif %}
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-slate-100 text-slate-700">
                            Uživatel
                        </span>
                        
                        {% if user.isActive %}
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-700">
                            <span class="w-2 h-2 rounded-full bg-green-500 mr-1.5"></span>
                            Aktivní
                        </span>
                        {% else %}
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-700">
                            <span class="w-2 h-2 rounded-full bg-red-500 mr-1.5"></span>
                            Neaktivní
                        </span>
                        {% endif %}
                    </div>
                    
                    <div class="flex gap-2 mt-6">
                        <a href="{{ path('app_nastaveni_admin_user_edit', {id: user.id}) }}"
                           class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                            Upravit
                        </a>
                        {% if user != app.user %}
                        <button type="button" 
                                onclick="document.getElementById('deleteModal').classList.remove('hidden')"
                                class="px-4 py-2 border border-red-300 text-red-600 hover:bg-red-50 font-medium rounded-lg transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                        </button>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Statistiky #}
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
                <h3 class="text-lg font-semibold text-slate-900 mb-4">Statistiky</h3>
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
                                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <span class="text-slate-600">Celkem hodin</span>
                        </div>
                        <span class="font-bold text-slate-900">{{ (totalMinutes / 60)|number_format(1) }}h</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-purple-100 flex items-center justify-center">
                                <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                </svg>
                            </div>
                            <span class="text-slate-600">Záznamů docházky</span>
                        </div>
                        <span class="font-bold text-slate-900">{{ totalDochazky }}</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-[rgb(241,97,1)]/10 flex items-center justify-center">
                                <svg class="w-5 h-5 text-[rgb(241,97,1)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                                </svg>
                            </div>
                            <span class="text-slate-600">Přiřazených zakázek</span>
                        </div>
                        <span class="font-bold text-slate-900">{{ assignedZakazky|length }}</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center">
                                <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <span class="text-slate-600">Registrace</span>
                        </div>
                        <span class="font-bold text-slate-900">{{ user.createdAt|date('d.m.Y') }}</span>
                    </div>
                </div>
            </div>
        </div>

        {# Pravá strana - Zakázky #}
        <div class="lg:col-span-2 space-y-6">
            {# Přidat zakázku #}
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-slate-900">Přiřadit zakázku</h3>
                    <span class="text-sm text-slate-500">{{ allZakazky|length }} dostupných</span>
                </div>
                
                <form action="{{ path('app_nastaveni_admin_user_add_zakazka', {id: user.id}) }}" method="POST" class="flex gap-3">
                    {% set availableZakazky = [] %}
                    {% for z in allZakazky %}
                        {% if z not in assignedZakazky %}
                            {% set availableZakazky = availableZakazky|merge([z]) %}
                        {% endif %}
                    {% endfor %}
                    
                    {% include 'components/_search_select.html.twig' with {
                        id: 'add_zakazka',
                        label: '',
                        items: availableZakazky,
                        itemIdField: 'id',
                        itemLabelField: 'name',
                        selectedId: '',
                        selectedLabel: '',
                        emptyOption: true,
                        emptyLabel: 'Vyberte zakázku...',
                        searchPlaceholder: 'Hledat zakázku...',
                        inputName: 'zakazka_id',
                        containerClass: 'flex-1'
                    } %}
                    
                    <button type="submit" 
                            class="px-6 py-2 bg-[rgb(241,97,1)] hover:bg-[rgb(220,85,0)] text-white font-medium rounded-lg transition-colors shadow-sm whitespace-nowrap">
                        <svg class="w-5 h-5 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                        </svg>
                        Přidat
                    </button>
                </form>
            </div>

            {# Seznam přiřazených zakázek #}
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-200">
                    <h3 class="text-lg font-semibold text-slate-900">Přiřazené zakázky</h3>
                    <p class="text-sm text-slate-500">Uživatel má přístup k těmto zakázkám a může na nich evidovat docházku</p>
                </div>
                
                {% if assignedZakazky|length > 0 %}
                <ul class="divide-y divide-slate-200">
                    {% for zakazka in assignedZakazky %}
                    <li class="px-6 py-4 hover:bg-slate-50 transition-colors">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
                                    <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                                    </svg>
                                </div>
                                <div>
                                    <h4 class="font-medium text-slate-900">{{ zakazka.name }}</h4>
                                    <div class="flex items-center gap-3 mt-1">
                                        {% if zakazka.status %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium 
                                            {% if zakazka.status.name == 'Aktivní' %}bg-green-100 text-green-700
                                            {% elseif zakazka.status.name == 'Dokončeno' %}bg-blue-100 text-blue-700
                                            {% else %}bg-slate-100 text-slate-700{% endif %}">
                                            {{ zakazka.status.name }}
                                        </span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex items-center gap-2">
                                <a href="{{ path('app_zakazka_detail', {id: zakazka.id}) }}" 
                                   class="p-2 text-slate-400 hover:text-[rgb(241,97,1)] hover:bg-[rgb(241,97,1)]/10 rounded-lg transition-colors"
                                   title="Detail zakázky">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                                    </svg>
                                </a>
                                <form action="{{ path('app_nastaveni_admin_user_remove_zakazka', {id: user.id, zakazkaId: zakazka.id}) }}" 
                                      method="POST"
                                      onsubmit="return confirm('Opravdu chcete odebrat uživateli přístup k této zakázce?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('remove-zakazka' ~ zakazka.id) }}">
                                    <button type="submit" 
                                            class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors"
                                            title="Odebrat zakázku">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <div class="px-6 py-12 text-center">
                    <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                    </div>
                    <h4 class="text-lg font-medium text-slate-900 mb-1">Žádné přiřazené zakázky</h4>
                    <p class="text-slate-500">Přidejte uživateli přístup k zakázkám pomocí formuláře výše</p>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# Delete Modal #}
<div id="deleteModal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:p-0">
        <div class="fixed inset-0 bg-slate-900/50 transition-opacity" onclick="document.getElementById('deleteModal').classList.add('hidden')"></div>
        
        <div class="relative bg-white rounded-2xl shadow-xl max-w-md w-full mx-auto p-6 text-left transform transition-all">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-900">Smazat uživatele</h3>
                    <p class="text-slate-500">Tato akce je nevratná</p>
                </div>
            </div>
            
            <p class="text-slate-600 mb-6">
                Opravdu chcete smazat uživatele <strong>{{ user.displayName }}</strong>? 
                Všechny související záznamy docházky budou také smazány.
            </p>
            
            <div class="flex gap-3">
                <button type="button" 
                        onclick="document.getElementById('deleteModal').classList.add('hidden')"
                        class="flex-1 px-4 py-2 border border-slate-300 text-slate-700 hover:bg-slate-50 font-medium rounded-lg transition-colors">
                    Zrušit
                </button>
                <form action="{{ path('app_nastaveni_admin_user_delete', {id: user.id}) }}" method="POST" class="flex-1">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                    <button type="submit" 
                            class="w-full px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-medium rounded-lg transition-colors">
                        Smazat
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
