{% extends 'layout/dashboard.html.twig' %}

{% block title %}Upravit fakturu #{{ faktura.id }}{% endblock %}

{% block content %}
{# Breadcrumb #}
<nav class="flex items-center space-x-2 text-sm mb-6">
    <a href="{{ path('app_faktura_index') }}" class="text-slate-500 hover:text-[rgb(241,97,1)] transition-colors">Faktury</a>
    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    {% if faktura.zakazka %}
        <a href="{{ path('app_zakazka_detail', {id: faktura.zakazka.id}) }}" class="text-slate-500 hover:text-[rgb(241,97,1)] transition-colors">{{ faktura.zakazka.name|length > 25 ? faktura.zakazka.name|slice(0, 25) ~ '...' : faktura.zakazka.name }}</a>
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
    {% endif %}
    <a href="{{ path('app_faktura_show', {id: faktura.id}) }}" class="text-slate-500 hover:text-[rgb(241,97,1)] transition-colors">Faktura #{{ faktura.id }}</a>
    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-slate-800 font-medium">Upravit</span>
</nav>

{# Header #}
<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
    <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
            <h1 class="text-2xl font-bold text-slate-800">Upravit fakturu #{{ faktura.id }}</h1>
            {% if faktura.status %}
                <span class="{{ faktura.status.badgeClasses }} px-3 py-1 rounded-full text-sm font-medium">{{ faktura.status.name }}</span>
            {% endif %}
        </div>
        <p class="text-slate-500">
            {% if faktura.zakazka %}Zakázka: <a href="{{ path('app_zakazka_detail', {id: faktura.zakazka.id}) }}" class="text-[rgb(241,97,1)] hover:underline">{{ faktura.zakazka.name }}</a> • {% endif %}
            Vytvořeno {{ faktura.createdAt ? faktura.createdAt|date('d.m.Y H:i') : '-' }}
        </p>
    </div>
    <div class="flex items-center space-x-3">
        <a href="{{ path('app_faktura_show', {id: faktura.id}) }}" class="inline-flex items-center px-4 py-2.5 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            Zobrazit
        </a>
    </div>
</div>

{# Flash messages #}
{% for message in app.flashes('success') %}
    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-green-700">{{ message }}</span>
        </div>
    </div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            <span class="text-red-700">{{ message }}</span>
        </div>
    </div>
{% endfor %}

<div class="space-y-6">

    {# Current file info #}
    {% if faktura.file %}
        <div class="bg-green-50 border border-green-200 rounded-xl p-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <div>
                        <p class="font-medium text-green-800">Aktuální soubor</p>
                        <p class="text-sm text-green-700">{{ faktura.originalFilename ?? faktura.file }}</p>
                    </div>
                </div>
                <a href="{{ path('app_faktura_file', {id: faktura.id}) }}" 
                   target="_blank"
                   class="px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition-colors">
                    Zobrazit
                </a>
            </div>
        </div>
    {% endif %}

    {# Form #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
        {{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data'}}) }}
        
        {# Zakázka - custom search select #}
        <div>
            <div class="hidden">{{ form_widget(form.zakazka) }}</div>
            {% include 'components/_search_select.html.twig' with {
                id: 'faktura_zakazka_search',
                label: 'Zakázka',
                items: form.zakazka.vars.choices,
                itemIdField: 'value',
                itemLabelField: 'label',
                selectedId: form.zakazka.vars.value,
                selectedLabel: form.zakazka.vars.value ? (form.zakazka.vars.choices|filter(c => c.value == form.zakazka.vars.value)|first).label|default('Vyberte zakázku') : 'Vyberte zakázku',
                emptyOption: false,
                searchPlaceholder: 'Hledat zakázku...'
            } %}
            {{ form_errors(form.zakazka) }}
        </div>

        {# Adresa/Popis #}
        <div>
            {{ form_label(form.adresa, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-2'}}) }}
            {{ form_widget(form.adresa, {'attr': {'class': 'w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[rgb(241,97,1)] focus:border-transparent resize-none'}}) }}
            {{ form_errors(form.adresa) }}
        </div>

        {# Ceny a datum grid #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {# Cena bez DPH #}
            <div>
                {{ form_label(form.cenaBezDph, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-2'}}) }}
                {{ form_widget(form.cenaBezDph, {'attr': {'class': 'w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[rgb(241,97,1)] focus:border-transparent'}}) }}
                <p class="text-xs text-slate-500 mt-1">{{ form.cenaBezDph.vars.help }}</p>
                {{ form_errors(form.cenaBezDph) }}
            </div>

            {# Datum #}
            <div>
                {{ form_label(form.datum, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-2'}}) }}
                {{ form_widget(form.datum, {'attr': {'class': 'w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[rgb(241,97,1)] focus:border-transparent'}}) }}
                {{ form_errors(form.datum) }}
            </div>
        </div>

        {# Aktuální vypočítané ceny #}
        {% if faktura.cenaSDph or faktura.cenaBezDaneZPrijmu %}
            <div class="bg-slate-50 rounded-xl p-4">
                <p class="text-sm font-medium text-slate-700 mb-2">Aktuálně vypočítané ceny:</p>
                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div>
                        <span class="text-slate-500">S DPH (21%):</span>
                        <span class="font-semibold text-[rgb(241,97,1)] ml-2">
                            {{ faktura.cenaSDph ? faktura.cenaSDph|number_format(2, ',', ' ') ~ ' Kč' : '-' }}
                        </span>
                    </div>
                    <div>
                        <span class="text-slate-500">Bez daně z příjmu (79%):</span>
                        <span class="font-semibold text-slate-900 ml-2">
                            {{ faktura.cenaBezDaneZPrijmu ? faktura.cenaBezDaneZPrijmu|number_format(2, ',', ' ') ~ ' Kč' : '-' }}
                        </span>
                    </div>
                </div>
            </div>
        {% endif %}

        {# Status #}
        <div>
            {{ form_label(form.status, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-2'}}) }}
            {{ form_widget(form.status, {'attr': {'class': 'w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[rgb(241,97,1)] focus:border-transparent'}}) }}
            {{ form_errors(form.status) }}
        </div>

        {# Soubor #}
        <div>
            {{ form_label(form.file, faktura.file ? 'Nahradit soubor' : 'Soubor faktury (PDF)', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-2'}}) }}
            <div class="border-2 border-dashed border-slate-300 rounded-xl p-6 text-center hover:border-[rgb(241,97,1)] transition-colors">
                {{ form_widget(form.file, {'attr': {'class': 'block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-medium file:bg-[rgb(241,97,1)] file:text-white hover:file:bg-[rgb(220,85,0)] cursor-pointer'}}) }}
                <p class="text-xs text-slate-500 mt-2">
                    {% if faktura.file %}
                        Nahrajte nový soubor pro nahrazení stávajícího
                    {% else %}
                        {{ form.file.vars.help }}
                    {% endif %}
                </p>
            </div>
            {{ form_errors(form.file) }}
        </div>

        {# Poznámka #}
        <div>
            {{ form_label(form.poznamka, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-2'}}) }}
            {{ form_widget(form.poznamka, {'attr': {'class': 'w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[rgb(241,97,1)] focus:border-transparent resize-none'}}) }}
            {{ form_errors(form.poznamka) }}
        </div>

        {# Buttons #}
        <div class="flex flex-col sm:flex-row gap-4 pt-4 border-t border-slate-200">
            <button type="submit" 
                    class="flex-1 px-6 py-3 bg-[rgb(241,97,1)] text-white font-medium rounded-xl hover:bg-[rgb(220,85,0)] transition-colors shadow-sm">
                <span class="flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Uložit změny
                </span>
            </button>
            <a href="{{ path('app_faktura_show', {id: faktura.id}) }}" 
               class="px-6 py-3 bg-slate-100 text-slate-700 font-medium rounded-xl hover:bg-slate-200 transition-colors text-center">
                Zrušit
            </a>
        </div>

        {{ form_end(form) }}
    </div>

    {# Delete button #}
    <div class="bg-red-50 border border-red-200 rounded-2xl p-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h3 class="font-medium text-red-900">Smazat fakturu</h3>
                <p class="text-sm text-red-700 mt-1">Tato akce je nevratná. Faktura i přiložený soubor budou trvale odstraněny.</p>
            </div>
            <form method="post" action="{{ path('app_faktura_delete', {id: faktura.id}) }}" 
                  onsubmit="return confirm('Opravdu chcete smazat tuto fakturu? Tato akce je nevratná.');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ faktura.id) }}">
                <button type="submit" 
                        class="px-4 py-2 bg-red-600 text-white font-medium rounded-xl hover:bg-red-700 transition-colors whitespace-nowrap">
                    Smazat fakturu
                </button>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Sync search select with form field
    const searchSelect = document.getElementById('faktura_zakazka_search');
    const formSelect = document.getElementById('faktura_zakazka');
    
    if (searchSelect && formSelect) {
        searchSelect.addEventListener('change', function() {
            formSelect.value = this.value;
        });
    }
});
</script>
{% endblock %}
