{% extends 'layout/dashboard.html.twig' %}

{% block title %}Faktury{% endblock %}

{% block content %}
{# Header s akcemi #}
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Faktury</h1>
        <p class="text-slate-500 mt-1">Celkem {{ faktury.getTotalItemCount }} faktur</p>
    </div>
    <a href="{{ path('app_faktura_new') }}" 
       class="inline-flex items-center justify-center px-5 py-2.5 bg-[rgb(241,97,1)] hover:bg-[rgb(220,88,0)] text-white font-medium rounded-xl shadow-lg shadow-[rgb(241,97,1)]/30 hover:shadow-[rgb(241,97,1)]/40 transition-all">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Nová faktura
    </a>
</div>

{# Filtry a vyhledávání #}
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-4 mb-6">
    <div class="flex flex-col lg:flex-row gap-4">
        {# Vyhledávání #}
        <form action="{{ path('app_faktura_index') }}" method="get" class="flex-1">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input 
                    type="text" 
                    name="search" 
                    value="{{ search }}"
                    placeholder="Hledat fakturu..." 
                    class="block w-full pl-10 pr-4 py-2.5 border border-slate-300 rounded-xl text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[rgb(241,97,1)] focus:border-transparent transition-all"
                >
            </div>
        </form>
        
        {# Filtr podle statusu #}
        <div class="flex flex-wrap items-center gap-2">
            <a href="{{ path('app_faktura_index') }}" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors text-center {{ not statusFilter ? 'bg-[rgb(241,97,1)] text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200' }}">
                Vše
            </a>
            {% for status in statusy %}
                <a href="{{ path('app_faktura_index', {status: status.id}) }}" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors text-center {{ statusFilter == status.id ? 'bg-[rgb(241,97,1)] text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200' }}">
                    {{ status.name }}
                </a>
            {% endfor %}
        </div>
    </div>
</div>

{# Flash messages #}
{% for message in app.flashes('success') %}
    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-green-700">{{ message }}</span>
        </div>
    </div>
{% endfor %}

{# Seznam faktur #}
{% if faktury is empty %}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-12 text-center">
        <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <h3 class="text-lg font-medium text-slate-900 mb-2">Žádné faktury</h3>
        <p class="text-slate-500 mb-6">Zatím nemáte žádné faktury. Vytvořte první!</p>
        <a href="{{ path('app_faktura_new') }}" 
           class="inline-flex items-center px-4 py-2 bg-[rgb(241,97,1)] text-white font-medium rounded-xl hover:bg-[rgb(220,85,0)] transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nová faktura
        </a>
    </div>
{% else %}
    {# Mobile cards #}
    <div class="lg:hidden space-y-4">
        {% for faktura in faktury %}
            <a href="{{ path('app_faktura_show', {id: faktura.id}) }}" 
               class="block bg-white rounded-2xl shadow-sm border border-slate-200 p-4 hover:shadow-md hover:border-[rgb(241,97,1)]/30 transition-all">
                <div class="flex justify-between items-start mb-3">
                    <div class="flex-1 min-w-0">
                        <h3 class="font-semibold text-slate-900 truncate">
                            {% if faktura.zakazka %}
                                {{ faktura.zakazka.name }}
                            {% else %}
                                Faktura #{{ faktura.id }}
                            {% endif %}
                        </h3>
                    </div>
                    {% if faktura.status %}
                        <span class="{{ faktura.status.badgeClasses }} text-xs px-2 py-1 rounded-full font-medium ml-2 whitespace-nowrap">
                            {{ faktura.status.name }}
                        </span>
                    {% endif %}
                </div>
                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div>
                        <span class="text-slate-500">Bez DPH:</span>
                        <span class="font-semibold text-slate-900 ml-1">{{ faktura.cenaBezDph ? faktura.cenaBezDph|number_format(2, ',', ' ') ~ ' Kč' : '-' }}</span>
                    </div>
                    <div>
                        <span class="text-slate-500">S DPH:</span>
                        <span class="font-semibold text-[rgb(241,97,1)] ml-1">{{ faktura.cenaSDph ? faktura.cenaSDph|number_format(2, ',', ' ') ~ ' Kč' : '-' }}</span>
                    </div>
                    <div>
                        <span class="text-slate-500">Datum:</span>
                        <span class="text-slate-700 ml-1">{{ faktura.datum ? faktura.datum|date('d.m.Y') : '-' }}</span>
                    </div>
                    <div>
                        {% if faktura.file %}
                            <span class="text-green-600 flex items-center">
                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                </svg>
                                Má soubor
                            </span>
                        {% endif %}
                    </div>
                </div>
            </a>
        {% endfor %}
    </div>

    {# Desktop table #}
    <div class="hidden lg:block bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Zakázka</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Bez DPH</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">S DPH</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Datum</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Soubor</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Akce</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    {% for faktura in faktury %}
                        <tr class="hover:bg-slate-50 transition-colors cursor-pointer" 
                            onclick="window.location='{{ path('app_faktura_show', {id: faktura.id}) }}'">
                            <td class="px-6 py-4">
                                <span class="font-medium text-slate-800">
                                    {% if faktura.zakazka %}
                                        {{ faktura.zakazka.name }}
                                    {% else %}
                                        <span class="text-slate-400">Bez zakázky</span>
                                    {% endif %}
                                </span>
                            </td>
                            <td class="px-6 py-4 text-slate-600">
                                {% if faktura.cenaBezDph %}
                                    {{ faktura.cenaBezDph|number_format(0, ',', ' ') }} Kč
                                {% else %}
                                    <span class="text-slate-400">-</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4">
                                {% if faktura.cenaSDph %}
                                    <span class="font-medium text-[rgb(241,97,1)]">{{ faktura.cenaSDph|number_format(0, ',', ' ') }} Kč</span>
                                {% else %}
                                    <span class="text-slate-400">-</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-slate-600">
                                {% if faktura.datum %}
                                    {{ faktura.datum|date('d.m.Y') }}
                                {% else %}
                                    <span class="text-slate-400">-</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4">
                                {% if faktura.status %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium {{ faktura.status.badgeClasses }}">
                                        {{ faktura.status.name }}
                                    </span>
                                {% else %}
                                    <span class="text-slate-400">-</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4" onclick="event.stopPropagation()">
                                {% if faktura.file %}
                                    <a href="{{ path('app_faktura_file', {id: faktura.id}) }}" 
                                       target="_blank"
                                       class="inline-flex items-center text-green-600 hover:text-green-700 transition-colors"
                                       title="Zobrazit soubor">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                        </svg>
                                    </a>
                                {% else %}
                                    <span class="text-slate-300">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                        </svg>
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-right" onclick="event.stopPropagation()">
                                <div class="flex items-center justify-end space-x-2">
                                    <a href="{{ path('app_faktura_show', {id: faktura.id}) }}" class="p-2 text-slate-400 hover:text-[rgb(241,97,1)] hover:bg-slate-100 rounded-lg transition-colors" title="Detail">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                    </a>
                                    <a href="{{ path('app_faktura_edit', {id: faktura.id}) }}" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Upravit">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Paginace #}
    {{ knp_pagination_render(faktury) }}
{% endif %}
{% endblock %}
