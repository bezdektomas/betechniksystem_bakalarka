{% extends 'layout/dashboard.html.twig' %}

{% block title %}Upravit zakázku | Betechnik IS{% endblock %}

{% block content %}
{# Breadcrumb #}
<nav class="flex items-center space-x-2 text-sm mb-6">
    <a href="{{ path('app_zakazka_list') }}" class="text-slate-500 hover:text-[rgb(241,97,1)] transition-colors">Zakázky</a>
    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <a href="{{ path('app_zakazka_detail', {id: zakazka.id}) }}" class="text-slate-500 hover:text-[rgb(241,97,1)] transition-colors">{{ zakazka.name|length > 30 ? zakazka.name|slice(0, 30) ~ '...' : zakazka.name }}</a>
    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-slate-800 font-medium">Upravit</span>
</nav>

{# Header #}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Upravit zakázku</h1>
</div>

{# Form Card #}
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-200">
        <h2 class="text-lg font-semibold text-slate-800">Údaje o zakázce</h2>
        <p class="text-sm text-slate-500 mt-1">Upravte potřebné údaje a uložte změny</p>
    </div>
    
    <div class="p-6">
        {{ form_start(form, {attr: {class: 'space-y-6'}}) }}
        
        {# Grid pro základní údaje #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {# Název #}
            <div class="md:col-span-2">
                <label for="{{ form.name.vars.id }}" class="block text-sm font-medium text-slate-700 mb-2">
                    Název zakázky <span class="text-red-500">*</span>
                </label>
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>
            
            {# Status #}
            <div>
                <label for="{{ form.status.vars.id }}" class="block text-sm font-medium text-slate-700 mb-2">
                    Status <span class="text-red-500">*</span>
                </label>
                {{ form_widget(form.status) }}
                {{ form_errors(form.status) }}
            </div>
            
            {# Cena #}
            <div>
                <label for="{{ form.price.vars.id }}" class="block text-sm font-medium text-slate-700 mb-2">
                    Předpokládaná cena (Kč)
                </label>
                {{ form_widget(form.price) }}
                {{ form_errors(form.price) }}
            </div>
            
            {# Datum realizace #}
            <div>
                <label for="{{ form.realizace.vars.id }}" class="block text-sm font-medium text-slate-700 mb-2">
                    Datum realizace
                </label>
                {{ form_widget(form.realizace) }}
                {{ form_errors(form.realizace) }}
            </div>
            
            {# URL #}
            <div>
                <label for="{{ form.url.vars.id }}" class="block text-sm font-medium text-slate-700 mb-2">
                    Odkaz / URL
                </label>
                {{ form_widget(form.url) }}
                {{ form_errors(form.url) }}
            </div>
        </div>
        
        {# Popis #}
        <div>
            <label for="{{ form.description.vars.id }}" class="block text-sm font-medium text-slate-700 mb-2">
                Popis zakázky
            </label>
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
            <p class="mt-1 text-sm text-slate-500">Podrobný popis toho, co je třeba udělat</p>
        </div>
        
        {# Poznámky #}
        <div>
            <label for="{{ form.notes.vars.id }}" class="block text-sm font-medium text-slate-700 mb-2">
                Interní poznámky
            </label>
            {{ form_widget(form.notes) }}
            {{ form_errors(form.notes) }}
            <p class="mt-1 text-sm text-slate-500">Poznámky viditelné pouze pro interní použití</p>
        </div>
        
        {# Přiřazení uživatelé #}
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-3">Přiřazení uživatelé</label>
            <div class="bg-slate-50 rounded-xl p-4 space-y-2">
                {% for child in form.assignedUsers %}
                    {% set userId = child.vars.value %}
                    {% set user = null %}
                    {% for u in users %}
                        {% if u.id == userId %}
                            {% set user = u %}
                        {% endif %}
                    {% endfor %}
                    <label class="flex items-center cursor-pointer group p-2 rounded-lg hover:bg-slate-100 transition-colors">
                        {{ form_widget(child, {'attr': {'class': 'w-4 h-4 text-[rgb(241,97,1)] border-slate-300 rounded focus:ring-[rgb(241,97,1)] focus:ring-2'}}) }}
                        <div class="ml-3 flex items-center gap-3">
                            {% if user and user.profilePicture %}
                            <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" 
                                 alt="{{ user.displayName }}"
                                 class="w-8 h-8 rounded-full object-cover border border-slate-200">
                            {% else %}
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-slate-400 to-slate-500 flex items-center justify-center text-white text-sm font-medium border border-slate-200">
                                {{ child.vars.label|first|upper }}
                            </div>
                            {% endif %}
                            <span class="text-slate-700 group-hover:text-slate-900 font-medium">{{ child.vars.label }}</span>
                        </div>
                    </label>
                {% else %}
                    <p class="text-slate-500 text-sm">Žádní aktivní uživatelé</p>
                {% endfor %}
            </div>
            {{ form_errors(form.assignedUsers) }}
        </div>
        
        {# Akce #}
        <div class="flex items-center justify-between pt-6 border-t border-slate-200">
            <a href="{{ path('app_zakazka_detail', {id: zakazka.id}) }}" class="inline-flex items-center px-4 py-2.5 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Zrušit
            </a>
            
            <button type="submit" class="inline-flex items-center px-6 py-2.5 bg-[rgb(241,97,1)] text-white font-semibold rounded-xl hover:bg-[rgb(230,90,0)] focus:outline-none focus:ring-2 focus:ring-[rgb(241,97,1)] focus:ring-offset-2 transition-all shadow-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Uložit změny
            </button>
        </div>
        
        {{ form_end(form) }}
    </div>
</div>

{# Informace o vytvoření #}
<div class="mt-6 p-4 bg-slate-50 rounded-xl border border-slate-200">
    <div class="flex items-center text-sm text-slate-500">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span>
            Zakázka vytvořena: {{ zakazka.createdAt|date('d.m.Y H:i') }} • {{ zakazka.createdBy.displayName }}
            {% if zakazka.updatedAt %}
                &nbsp;•&nbsp; Poslední úprava: {{ zakazka.updatedAt|date('d.m.Y H:i') }}
            {% endif %}
        </span>
    </div>
</div>
{% endblock %}
