{% extends 'layout/dashboard.html.twig' %}

{% block title %}{{ zakazka.name }} | Betechnik IS{% endblock %}

{% block content %}
{# Breadcrumb #}
<nav class="flex items-center space-x-2 text-sm mb-6">
    <a href="{{ path('app_zakazka_list') }}" class="text-slate-500 hover:text-[rgb(241,97,1)] transition-colors">Zakázky</a>
    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-slate-800 font-medium">{{ zakazka.name|length > 40 ? zakazka.name|slice(0, 40) ~ '...' : zakazka.name }}</span>
</nav>

{# Flash messages #}
{% for message in app.flashes('success') %}
    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-green-700">{{ message }}</span>
        </div>
    </div>
{% endfor %}

{# Header #}
<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
    <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
            <h1 class="text-2xl font-bold text-slate-800">{{ zakazka.name }}</h1>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium {{ zakazka.status.badgeClasses }}">
                {{ zakazka.status.name }}
            </span>
        </div>
        <p class="text-slate-500">
            Vytvořeno {{ zakazka.createdAt|date('d.m.Y H:i') }} • {{ zakazka.createdBy.displayName }}
            {% if zakazka.updatedAt %}
                • Upraveno {{ zakazka.updatedAt|date('d.m.Y H:i') }}
            {% endif %}
        </p>
    </div>
    
    <div class="flex items-center space-x-3">
        <form action="{{ path('app_chat_zakazka', {zakazkaId: zakazka.id}) }}" method="POST">
            <button type="submit" class="inline-flex items-center px-4 py-2.5 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                Chat
            </button>
        </form>

        <a href="{{ path('app_zakazka_edit', {id: zakazka.id}) }}" class="inline-flex items-center px-4 py-2.5 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Upravit
        </a>
        
        {# Delete button with confirmation #}
        <form action="{{ path('app_zakazka_delete', {id: zakazka.id}) }}" method="post" onsubmit="return confirm('Opravdu chcete smazat tuto zakázku? Tato akce je nevratná.');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ zakazka.id) }}">
            <button type="submit" class="inline-flex items-center px-4 py-2.5 bg-white border border-red-300 text-red-600 font-medium rounded-xl hover:bg-red-50 transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Smazat
            </button>
        </form>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    {# Hlavní obsah #}
    <div class="lg:col-span-2 space-y-6">
        {# Popis #}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
                <h2 class="text-lg font-semibold text-slate-800">Popis</h2>
            </div>
            <div class="p-6">
                {% if zakazka.description %}
                    <div class="prose prose-slate max-w-none">
                        {{ zakazka.description|nl2br }}
                    </div>
                {% else %}
                    <p class="text-slate-400 italic">Bez popisu</p>
                {% endif %}
            </div>
        </div>
        
        {# Poznámky #}
        {% if zakazka.notes %}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
                <h2 class="text-lg font-semibold text-slate-800">Poznámky</h2>
            </div>
            <div class="p-6">
                <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
                    <div class="prose prose-slate max-w-none text-yellow-900">
                        {{ zakazka.notes|nl2br }}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
        
        {# Faktury #}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 border-b border-slate-200 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-800">Faktury</h2>
                <a href="{{ path('app_faktura_new', {zakazka: zakazka.id}) }}" 
                   class="inline-flex items-center px-3 py-1.5 bg-[rgb(241,97,1)] text-white text-sm font-medium rounded-lg hover:bg-[rgb(220,85,0)] transition-colors">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Nová faktura
                </a>
            </div>
            <div class="p-6">
                {% if zakazka.faktury|length > 0 %}
                    <div class="space-y-3">
                        {% for faktura in zakazka.faktury %}
                            <a href="{{ path('app_faktura_show', {id: faktura.id}) }}" 
                               class="flex items-center justify-between p-4 bg-slate-50 rounded-xl hover:bg-slate-100 transition-colors group">
                                <div class="flex items-center space-x-4">
                                    <div class="w-10 h-10 rounded-lg bg-[rgb(241,97,1)]/10 flex items-center justify-center">
                                        <svg class="w-5 h-5 text-[rgb(241,97,1)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="font-medium text-slate-800 group-hover:text-[rgb(241,97,1)] transition-colors">
                                            {{ faktura.adresa ? faktura.adresa|slice(0, 40) ~ (faktura.adresa|length > 40 ? '...' : '') : 'Faktura #' ~ faktura.id }}
                                        </div>
                                        <div class="text-sm text-slate-500">
                                            {{ faktura.datum ? faktura.datum|date('d.m.Y') : 'Bez data' }}
                                            {% if faktura.status %}
                                                • <span class="{{ faktura.status.badgeClasses }} text-xs px-2 py-0.5 rounded-full">{{ faktura.status.name }}</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="font-bold text-[rgb(241,97,1)]">
                                        {{ faktura.cenaSDph ? faktura.cenaSDph|number_format(0, ',', ' ') ~ ' Kč' : '-' }}
                                    </div>
                                    <div class="text-xs text-slate-500">s DPH</div>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                    
                    {# Souhrn #}
                    {% set sumBezDph = 0 %}
                    {% set sumSDph = 0 %}
                    {% for faktura in zakazka.faktury %}
                        {% set sumBezDph = sumBezDph + (faktura.cenaBezDph ?? 0) %}
                        {% set sumSDph = sumSDph + (faktura.cenaSDph ?? 0) %}
                    {% endfor %}
                    {% if sumSDph > 0 %}
                        <div class="mt-4 pt-4 border-t border-slate-200 flex justify-between items-center">
                            <span class="text-sm text-slate-600">Celkem ({{ zakazka.faktury|length }} {{ zakazka.faktury|length == 1 ? 'faktura' : (zakazka.faktury|length < 5 ? 'faktury' : 'faktur') }})</span>
                            <div class="text-right">
                                <div class="font-bold text-lg text-slate-900">{{ sumSDph|number_format(0, ',', ' ') }} Kč</div>
                                <div class="text-xs text-slate-500">{{ sumBezDph|number_format(0, ',', ' ') }} Kč bez DPH</div>
                            </div>
                        </div>
                    {% endif %}
                {% else %}
                    <div class="text-center py-8">
                        <svg class="w-12 h-12 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <p class="text-slate-500 mb-4">Žádné faktury k této zakázce</p>
                        <a href="{{ path('app_faktura_new', {zakazka: zakazka.id}) }}" 
                           class="inline-flex items-center px-4 py-2 bg-[rgb(241,97,1)] text-white font-medium rounded-xl hover:bg-[rgb(220,85,0)] transition-colors">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                            </svg>
                            Vytvořit první fakturu
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
        
        {# Přístupy #}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 border-b border-slate-200 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-800">Přístupy</h2>
                <a href="{{ path('app_pristup_new', {zakazka: zakazka.id}) }}" 
                   class="inline-flex items-center px-3 py-1.5 bg-[rgb(241,97,1)] text-white text-sm font-medium rounded-lg hover:bg-[rgb(220,85,0)] transition-colors">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Nový přístup
                </a>
            </div>
            <div class="p-6">
                {% if zakazka.pristupy|length > 0 %}
                    <div class="space-y-4">
                        {% for pristup in zakazka.pristupy %}
                            <div class="p-4 bg-slate-50 rounded-xl border border-slate-200">
                                <div class="flex items-start justify-between mb-3">
                                    <div>
                                        <h4 class="font-medium text-slate-800">{{ pristup.popis }}</h4>
                                        {% if pristup.url %}
                                            <a href="{{ pristup.url }}" target="_blank" class="text-sm text-[rgb(241,97,1)] hover:underline flex items-center gap-1 mt-1">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                                                </svg>
                                                {{ pristup.url|length > 50 ? pristup.url[:50] ~ '...' : pristup.url }}
                                            </a>
                                        {% endif %}
                                    </div>
                                    <a href="{{ path('app_pristup_edit', {id: pristup.id}) }}" 
                                       class="p-1.5 text-slate-400 hover:text-[rgb(241,97,1)] transition-colors"
                                       title="Upravit">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                    </a>
                                </div>
                                
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                    {# Username #}
                                    {% if pristup.username %}
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs text-slate-500 w-16">Uživatel:</span>
                                        <code class="px-2 py-1 bg-white border border-slate-200 text-slate-700 rounded text-sm font-mono flex-1 truncate">{{ pristup.username }}</code>
                                        <button type="button" 
                                                onclick="copyToClipboard('{{ pristup.username|e('js') }}', this)"
                                                class="p-1.5 text-slate-400 hover:text-[rgb(241,97,1)] transition-colors flex-shrink-0"
                                                title="Kopírovat">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                                            </svg>
                                        </button>
                                    </div>
                                    {% endif %}
                                    
                                    {# Password #}
                                    {% if pristup.password %}
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs text-slate-500 w-16">Heslo:</span>
                                        <code class="px-2 py-1 bg-white border border-slate-200 text-slate-700 rounded text-sm font-mono flex-1 truncate password-field" data-password="{{ pristup.password|e('html_attr') }}">••••••••</code>
                                        <button type="button" 
                                                onclick="togglePassword(this)"
                                                class="p-1.5 text-slate-400 hover:text-[rgb(241,97,1)] transition-colors flex-shrink-0"
                                                title="Zobrazit/skrýt">
                                            <svg class="w-4 h-4 eye-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                            </svg>
                                            <svg class="w-4 h-4 eye-off-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                            </svg>
                                        </button>
                                        <button type="button" 
                                                onclick="copyToClipboard('{{ pristup.password|e('js') }}', this)"
                                                class="p-1.5 text-slate-400 hover:text-[rgb(241,97,1)] transition-colors flex-shrink-0"
                                                title="Kopírovat">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                                            </svg>
                                        </button>
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-8">
                        <svg class="w-12 h-12 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                        </svg>
                        <p class="text-slate-500 mb-4">Žádné přístupy k této zakázce</p>
                        <a href="{{ path('app_pristup_new', {zakazka: zakazka.id}) }}" 
                           class="inline-flex items-center px-4 py-2 bg-[rgb(241,97,1)] text-white font-medium rounded-xl hover:bg-[rgb(220,85,0)] transition-colors">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                            </svg>
                            Přidat první přístup
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
        
        {# Docházka #}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 border-b border-slate-200 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-800">Docházka</h2>
                <div class="flex items-center gap-2">
                    <a href="{{ path('app_dochazka_zakazka', {id: zakazka.id}) }}" 
                       class="inline-flex items-center px-3 py-1.5 bg-white border border-slate-300 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors">
                        Zobrazit vše
                    </a>
                    <a href="{{ path('app_dochazka_new', {zakazka: zakazka.id}) }}" 
                       class="inline-flex items-center px-3 py-1.5 bg-[rgb(241,97,1)] text-white text-sm font-medium rounded-lg hover:bg-[rgb(220,85,0)] transition-colors">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        Přidat
                    </a>
                </div>
            </div>
            <div class="p-6">
                {% set totalMinutes = zakazka.totalWorkedMinutes %}
                {% set lastDochazky = zakazka.dochazky|slice(0, 5) %}
                
                {% if totalMinutes > 0 %}
                    {# Summary #}
                    <div class="flex items-center justify-between mb-4 p-4 bg-emerald-50 rounded-xl border border-emerald-200">
                        <span class="text-sm font-medium text-emerald-800">Celkem odpracováno</span>
                        <span class="text-xl font-bold text-emerald-700">{{ zakazka.formattedTotalTime }}</span>
                    </div>
                    
                    {# Recent records #}
                    <div class="space-y-2">
                        {% for dochazka in lastDochazky %}
                        <div class="flex items-center justify-between py-2 px-3 bg-slate-50 rounded-lg text-sm">
                            <div class="flex items-center gap-2">
                                <span class="text-slate-600">{{ dochazka.datum|date('d.m.') }}</span>
                                <span class="text-slate-400">{{ dochazka.user.displayName }}</span>
                            </div>
                            <span class="font-medium text-slate-700">{{ dochazka.formattedTime }}</span>
                        </div>
                        {% endfor %}
                    </div>
                    
                    {% if zakazka.dochazky|length > 5 %}
                    <div class="mt-3 text-center">
                        <a href="{{ path('app_dochazka_zakazka', {id: zakazka.id}) }}" class="text-sm text-[rgb(241,97,1)] hover:underline">
                            Zobrazit všechny záznamy ({{ zakazka.dochazky|length }})
                        </a>
                    </div>
                    {% endif %}
                {% else %}
                    <div class="text-center py-8">
                        <svg class="w-12 h-12 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <p class="text-slate-500 mb-4">Zatím žádná docházka</p>
                        <a href="{{ path('app_dochazka_new', {zakazka: zakazka.id}) }}" 
                           class="inline-flex items-center px-4 py-2 bg-[rgb(241,97,1)] text-white font-medium rounded-xl hover:bg-[rgb(220,85,0)] transition-colors">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                            </svg>
                            Přidat docházku
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    
    {# Boční panel #}
    <div class="space-y-6">
        {# Detaily #}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
                <h2 class="text-lg font-semibold text-slate-800">Detaily</h2>
            </div>
            <div class="p-6 space-y-4">
                {# Cena #}
                <div>
                    <dt class="text-sm font-medium text-slate-500 mb-1">Předpokládaná cena</dt>
                    <dd class="text-xl font-bold text-slate-800">
                        {% if zakazka.price %}
                            {{ zakazka.price|number_format(0, ',', ' ') }} Kč
                        {% else %}
                            <span class="text-slate-400 font-normal">Neuvedeno</span>
                        {% endif %}
                    </dd>
                </div>
                
                {# Status změna #}
                <div class="col-span-full">
                    <dt class="text-sm font-medium text-slate-500 mb-3">Status</dt>
                    <form action="{{ path('app_zakazka_change_status', {id: zakazka.id}) }}" method="post" id="zakazka-status-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('status' ~ zakazka.id) }}">
                        <input type="hidden" name="status" id="zakazka-status-input" value="{{ zakazka.status ? zakazka.status.id : '' }}">
                        <div class="flex flex-wrap gap-2">
                            {% for status in statusy %}
                                {% set isActive = zakazka.status and zakazka.status.id == status.id %}
                                <button type="button"
                                        onclick="confirmStatusChange(this)"
                                        data-status-id="{{ status.id }}"
                                        data-status-name="{{ status.name }}"
                                        data-input="zakazka-status-input"
                                        data-form="zakazka-status-form"
                                        class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-sm font-medium transition-all {{ status.badgeClasses }} {{ isActive ? 'ring-2 ring-offset-2 ring-current shadow-sm scale-105' : 'opacity-50 hover:opacity-90 hover:scale-105 cursor-pointer' }}">
                                    {% if isActive %}
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    {% endif %}
                                    {{ status.name }}
                                </button>
                            {% endfor %}
                        </div>
                    </form>
                </div>
                
                {# Datum realizace #}
                <div>
                    <dt class="text-sm font-medium text-slate-500 mb-1">Datum realizace</dt>
                    <dd class="text-slate-800">
                        {% if zakazka.realizace %}
                            {{ zakazka.realizace|date('d.m.Y') }}
                        {% else %}
                            <span class="text-slate-400">Neuvedeno</span>
                        {% endif %}
                    </dd>
                </div>
                
                {# URL #}
                {% if zakazka.url %}
                <div>
                    <dt class="text-sm font-medium text-slate-500 mb-1">Odkaz</dt>
                    <dd>
                        <a href="{{ zakazka.url }}" target="_blank" class="text-[rgb(241,97,1)] hover:underline break-all flex items-center">
                            <svg class="w-4 h-4 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                            </svg>
                            <span class="truncate">{{ zakazka.url|length > 30 ? zakazka.url|slice(0, 30) ~ '...' : zakazka.url }}</span>
                        </a>
                    </dd>
                </div>
                {% endif %}
            </div>
        </div>
        
        {# Přiřazení uživatelé #}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 border-b border-slate-200">
                <h2 class="text-lg font-semibold text-slate-800">Přiřazení uživatelé</h2>
            </div>
            <div class="p-6">
                {% if zakazka.assignedUsers|length > 0 %}
                    <ul class="space-y-3">
                        {% for user in zakazka.assignedUsers %}
                            <li class="flex items-center">
                                {% if user.profilePicture %}
                                <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" 
                                     alt="{{ user.displayName }}"
                                     class="w-8 h-8 rounded-full object-cover mr-3">
                                {% else %}
                                <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-sm font-medium text-slate-700 mr-3">
                                    {{ user.email|first|upper }}
                                </div>
                                {% endif %}
                                <div>
                                    <div class="text-sm font-medium text-slate-800">{{ user.displayName }}</div>
                                    <div class="text-xs text-slate-500">{{ user.email }}</div>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-slate-400 text-sm">Žádní přiřazení uživatelé</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function copyToClipboard(text, button) {
    navigator.clipboard.writeText(text).then(function() {
        // Visual feedback
        const originalContent = button.innerHTML;
        button.innerHTML = '<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(function() {
            button.innerHTML = originalContent;
        }, 1500);
    });
}

function togglePassword(button) {
    const container = button.closest('.flex');
    const codeEl = container.querySelector('.password-field');
    const eyeIcon = button.querySelector('.eye-icon');
    const eyeOffIcon = button.querySelector('.eye-off-icon');
    
    if (codeEl.textContent === '••••••••') {
        codeEl.textContent = codeEl.dataset.password;
        eyeIcon.classList.add('hidden');
        eyeOffIcon.classList.remove('hidden');
    } else {
        codeEl.textContent = '••••••••';
        eyeIcon.classList.remove('hidden');
        eyeOffIcon.classList.add('hidden');
    }
}
</script>
{% endblock %}
