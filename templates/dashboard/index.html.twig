{% extends 'layout/dashboard.html.twig' %}

{% block title %}Nástěnka | Betechnik IS{% endblock %}

{% block content %}
<style>
@keyframes blob-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%       { transform: translate(50px, -60px) scale(1.25); }
    66%       { transform: translate(-40px, 35px) scale(0.82); }
}
@keyframes blob-float-slow {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40%       { transform: translate(-55px, 50px) scale(1.28); }
    75%       { transform: translate(40px, -50px) scale(0.80); }
}
@keyframes pulse-glow {
    0%, 100% { opacity: 0.35; }
    50%       { opacity: 1; }
}
@keyframes pulse-glow-soft {
    0%, 100% { opacity: 0.15; }
    50%       { opacity: 0.7; }
}
.blob-1 { animation: blob-float 7s ease-in-out infinite; }
.blob-2 { animation: blob-float-slow 10s ease-in-out infinite; }
.glow-1 { animation: pulse-glow 4s ease-in-out infinite; }
.glow-2 { animation: pulse-glow-soft 5s ease-in-out infinite 0.8s; }
</style>
<div class="relative sm:hidden -mx-4 -mt-4 -mb-4 min-h-screen overflow-hidden bg-[radial-gradient(circle_at_top,_rgba(251,146,60,0.34),_transparent_34%),linear-gradient(180deg,_rgb(101,47,27)_0%,_rgb(59,38,48)_20%,_rgb(24,35,63)_52%,_rgb(9,9,11)_100%)]">
    <div class="glow-1 pointer-events-none absolute inset-x-0 top-0 h-[28rem] bg-[radial-gradient(circle_at_top,_rgba(251,146,60,0.42),_transparent_62%)]"></div>
    <div class="glow-2 pointer-events-none absolute inset-x-0 top-24 h-64 bg-[radial-gradient(circle_at_center,_rgba(249,115,22,0.18),_transparent_70%)]"></div>
    <div class="blob-1 pointer-events-none absolute -top-10 right-[-72px] h-64 w-64 rounded-full bg-orange-500/24 blur-3xl"></div>
    <div class="blob-2 pointer-events-none absolute left-[-88px] top-56 h-72 w-72 rounded-full bg-amber-400/14 blur-3xl"></div>

    <div class="relative z-10 px-4 pt-6 pb-8">
        <div class="rounded-[2rem] border border-orange-200/15 bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.04))] px-5 py-6 shadow-[0_24px_80px_rgba(0,0,0,0.35)] backdrop-blur-xl">
            <div class="text-center">
                <p class="text-white/65 text-sm font-medium mb-1">Měsíční obrat</p>
                <p class="text-4xl font-bold tracking-tight text-white">{{ stats.mesicni_obrat|number_format(0, ',', ' ') }} Kč</p>
                <p class="text-white/45 text-xs mt-1">{{ "now"|date("n") | replace({
                    '1':'Leden','2':'Únor','3':'Březen','4':'Duben','5':'Květen','6':'Červen',
                    '7':'Červenec','8':'Srpen','9':'Září','10':'Říjen','11':'Listopad','12':'Prosinec'
                }) }} {{ "now"|date("Y") }}</p>
                <div class="mt-4 inline-flex items-center rounded-full border border-orange-300/20 bg-white/[0.08] px-4 py-1.5 text-xs font-medium text-orange-100">
                    Přehled zakázek
                </div>
            </div>

            <div class="mt-7 grid grid-cols-4 gap-3">
                <a href="{{ path('app_zakazka_new') }}" class="flex flex-col items-center gap-2 text-center group">
                    <div class="flex h-14 w-14 items-center justify-center rounded-full border border-white/10 bg-white/[0.08] transition-transform group-active:scale-95">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                    </div>
                    <span class="text-[11px] font-medium text-white/80">Zakázka</span>
                </a>
                <a href="{{ path('app_dochazka_index') }}" class="flex flex-col items-center gap-2 text-center group">
                    <div class="flex h-14 w-14 items-center justify-center rounded-full border border-white/10 bg-white/[0.08] transition-transform group-active:scale-95">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <span class="text-[11px] font-medium text-white/80">Docházka</span>
                </a>
                <a href="{{ path('app_chat_index') }}" class="flex flex-col items-center gap-2 text-center group">
                    <div class="flex h-14 w-14 items-center justify-center rounded-full border border-white/10 bg-white/[0.08] transition-transform group-active:scale-95">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                        </svg>
                    </div>
                    <span class="text-[11px] font-medium text-white/80">Chat</span>
                </a>
                <a href="{{ path('app_faktura_index') }}" class="flex flex-col items-center gap-2 text-center group">
                    <div class="flex h-14 w-14 items-center justify-center rounded-full border border-white/10 bg-white/[0.08] transition-transform group-active:scale-95">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <span class="text-[11px] font-medium text-white/80">Faktury</span>
                </a>
            </div>
        </div>

        <div class="mt-5 grid grid-cols-2 gap-3">
            <a href="{{ path('app_zakazka_list', {status: 1}) }}" class="rounded-[1.6rem] border border-white/10 bg-white/[0.07] p-4 shadow-[0_14px_36px_rgba(0,0,0,0.22)] backdrop-blur-xl active:bg-white/[0.11]">
                <div class="mb-4 flex items-center justify-between">
                    <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-blue-400/15 text-blue-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                        </svg>
                    </div>
                </div>
                <p class="text-3xl font-bold text-white">{{ stats.nezpracovane }}</p>
                <p class="mt-1 text-xs font-medium text-white/60">Nezpracované</p>
            </a>

            <a href="{{ path('app_zakazka_list', {status: 3}) }}" class="rounded-[1.6rem] border border-white/10 bg-white/[0.07] p-4 shadow-[0_14px_36px_rgba(0,0,0,0.22)] backdrop-blur-xl active:bg-white/[0.11]">
                <div class="mb-4 flex items-center justify-between">
                    <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-orange-400/15 text-orange-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                    </div>
                </div>
                <p class="text-3xl font-bold text-white">{{ stats.v_realizaci }}</p>
                <p class="mt-1 text-xs font-medium text-white/60">V realizaci</p>
            </a>

            <div class="rounded-[1.6rem] border border-white/10 bg-white/[0.07] p-4 shadow-[0_14px_36px_rgba(0,0,0,0.22)] backdrop-blur-xl">
                <div class="mb-4 flex items-center justify-between">
                    <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-400/15 text-emerald-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                </div>
                <p class="text-3xl font-bold text-white">{{ stats.dokonceno_mesic }}</p>
                <p class="mt-1 text-xs font-medium text-white/60">Dokončeno</p>
            </div>

            <a href="{{ path('app_zakazka_list') }}" class="rounded-[1.6rem] border border-white/10 bg-white/[0.07] p-4 shadow-[0_14px_36px_rgba(0,0,0,0.22)] backdrop-blur-xl active:bg-white/[0.11]">
                <div class="mb-4 flex items-center justify-between">
                    <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-violet-400/15 text-violet-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                    </div>
                </div>
                <p class="text-3xl font-bold text-white">{{ stats.nezpracovane + stats.v_realizaci + stats.dokonceno_mesic }}</p>
                <p class="mt-1 text-xs font-medium text-white/60">Celkem zakázek</p>
            </a>
        </div>

        <div class="mt-7 pb-6">
            <div class="mb-3 flex items-center justify-between px-1">
                <h2 class="text-base font-semibold text-white">Poslední nezpracované zakázky</h2>
                <a href="{{ path('app_zakazka_list') }}" class="text-sm font-medium text-orange-200">Vše</a>
            </div>

            <div class="overflow-hidden rounded-[1.8rem] border border-white/10 bg-white/[0.07] shadow-[0_18px_40px_rgba(0,0,0,0.25)] backdrop-blur-xl divide-y divide-white/10">
                {% for zakazka in zakazkyNezpracovane|slice(0, 5) %}
                <a href="{{ path('app_zakazka_detail', {id: zakazka.id}) }}" class="flex items-center p-4 active:bg-white/[0.08]">
                    <div class="mr-3 flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/10 text-sm font-semibold text-white">
                        {{ zakazka.name|slice(0, 2)|upper }}
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="truncate font-medium text-white">{{ zakazka.name }}</p>
                        <p class="flex items-center gap-1.5 text-xs text-white/55">
                            <span class="inline-block h-1.5 w-1.5 rounded-full" style="background-color: {{ zakazka.status.color ?? '#fb923c' }}"></span>
                            {{ zakazka.status.name }}
                        </p>
                    </div>
                    <div class="ml-2 text-right">
                        {% if zakazka.price %}
                        <p class="font-semibold text-white">{{ zakazka.price|number_format(0, ',', ' ') }} Kč</p>
                        {% else %}
                        <p class="text-white/35">—</p>
                        {% endif %}
                        <p class="text-xs text-white/40">{{ zakazka.createdAt|date('d.m.') }}</p>
                    </div>
                </a>
                {% else %}
                <div class="p-8 text-center">
                    <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full border border-white/10 bg-white/10 text-white/55">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                        </svg>
                    </div>
                    <p class="text-sm text-white/60">Žádné zakázky</p>
                    <a href="{{ path('app_zakazka_new') }}" class="mt-2 inline-block text-sm font-medium text-orange-200">+ Vytvořit zakázku</a>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{# ========== DESKTOP DASHBOARD (unchanged) ========== #}
{# Stats Cards Row #}
<div class="hidden sm:grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 mb-6">
    {# Nezpracované zakázky #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm font-medium text-slate-500 uppercase tracking-wide">Nezpracované zakázky</p>
                <p class="text-3xl font-bold text-slate-800 mt-2">{{ stats.nezpracovane }}</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                </svg>
            </div>
        </div>
    </div>
    
    {# V realizaci #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm font-medium text-slate-500 uppercase tracking-wide">V realizaci</p>
                <p class="text-3xl font-bold text-slate-800 mt-2">{{ stats.v_realizaci }}</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-[rgba(241,97,1,0.1)] flex items-center justify-center">
                <svg class="w-6 h-6 text-[rgb(241,97,1)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
            </div>
        </div>
    </div>
    
    {# Měsíční obrat #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm font-medium text-slate-500 uppercase tracking-wide">Měsíční obrat</p>
                <p class="text-3xl font-bold text-slate-800 mt-2">{{ stats.mesicni_obrat|number_format(0, ',', ' ') }} Kč</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
        </div>
    </div>
    
    {# Dokončeno tento měsíc #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm font-medium text-slate-500 uppercase tracking-wide">Dokončeno (měsíc)</p>
                <p class="text-3xl font-bold text-slate-800 mt-2">{{ stats.dokonceno_mesic }}</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
        </div>
    </div>
</div>

{# Tables Section #}
<div class="hidden sm:grid grid-cols-1 xl:grid-cols-2 gap-6">
    {# Nezpracované zakázky #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-800">Nezpracované zakázky</h2>
                <a href="{{ path('app_zakazka_list', {status: 1}) }}" class="text-sm font-medium text-[rgb(241,97,1)] hover:text-[rgb(220,88,0)] transition-colors">
                    Zobrazit vše →
                </a>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Název</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Cena</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Datum</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    {% for zakazka in zakazkyNezpracovane %}
                    <tr class="hover:bg-slate-50 transition-colors cursor-pointer" onclick="window.location='{{ path('app_zakazka_detail', {id: zakazka.id}) }}'">
                        <td class="px-6 py-4">
                            <span class="font-medium text-slate-800">
                                {{ zakazka.name }}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-slate-600">
                            {% if zakazka.price %}
                                {{ zakazka.price|number_format(0, ',', ' ') }} Kč
                            {% else %}
                                <span class="text-slate-400">-</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ zakazka.status.badgeClasses }}">
                                {{ zakazka.status.name }}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-slate-500 text-sm">
                            {{ zakazka.createdAt|date('d.m.Y') }}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" class="px-6 py-8 text-center text-slate-500">
                            <p class="mb-2">Žádné nezpracované zakázky</p>
                            <a href="{{ path('app_zakazka_new') }}" class="text-[rgb(241,97,1)] hover:underline">+ Vytvořit novou zakázku</a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    {# Zakázky v realizaci #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-800">Zakázky v realizaci</h2>
                <a href="{{ path('app_zakazka_list', {status: 3}) }}" class="text-sm font-medium text-[rgb(241,97,1)] hover:text-[rgb(220,88,0)] transition-colors">
                    Zobrazit vše →
                </a>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Název</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Cena</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Datum</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    {% for zakazka in zakazkyVRealizaci %}
                    <tr class="hover:bg-slate-50 transition-colors cursor-pointer" onclick="window.location='{{ path('app_zakazka_detail', {id: zakazka.id}) }}'">
                        <td class="px-6 py-4">
                            <span class="font-medium text-slate-800">
                                {{ zakazka.name }}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-slate-600">
                            {% if zakazka.price %}
                                {{ zakazka.price|number_format(0, ',', ' ') }} Kč
                            {% else %}
                                <span class="text-slate-400">-</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ zakazka.status.badgeClasses }}">
                                {{ zakazka.status.name }}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-slate-500 text-sm">
                            {{ zakazka.createdAt|date('d.m.Y') }}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" class="px-6 py-8 text-center text-slate-500">
                            Žádné zakázky v realizaci
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
